---
import AboutLayout from '../../layouts/AboutLayout.astro';
import heroImg from '../../assets/about/careers/9d36c932f523a740b4e616018c32e8cf6807c960.png';
import introImg from '../../assets/about/careers/acb7f6fdfb8cc0bbaeea7fa9d84f57f60b4aef04.png';
import cultureImg from '../../assets/about/careers/0aaa54070576742e39b9fe8728b45ee73f715613.png';
import avatarAdam from '../../assets/about/careers/4626be44b284b8b1ee6284f743bcc3a42a902da1.png';
import avatarFawaaz1 from '../../assets/about/careers/e3a1b1cac1bdf2b1d67ac45543b814862b0858b6.png';
import avatarFawaaz2 from '../../assets/about/careers/ba96183393ff9a64923b8099b9d32083d5b2f315.png';
import reachOutImg from '../../assets/about/careers/60c26e97b304b786a121896cb8a9ba9c10e748e0.png';

const accordionItems = [
  {
    title: 'Compensation',
    body:
      'Employees receive competitive wages and receive annual raises as they develop new skills, grow in their roles, and take on greater responsibility. Paid time off and paid holidays give employees time to step away, recharge, and maintain balance outside of work. A 401(k) plan with employer match supports long-term financial planning.',
  },
  {
    title: 'Medical',
    body:
      'Access to quality health care is deeply important to Shuert. As a self-insured company, Shuert directly funds medical coverage for employees and their families, with no employee-paid premiums. Employees also receive company-paid Life Insurance, Accidental Death and Disability, and Short-Term Disability coverage for added peace of mind. Policies are reviewed yearly to help ensure employees and their families have access to comprehensive, high-quality coverage.',
  },
  {
    title: 'Opportunity',
    body:
      'All levels of experience are welcome at Shuert. Whether someone is starting their career, learning a new role, or bringing years of experience to the team, there are opportunities to grow. As advocates of promoting from within, employees are encouraged to learn new skills, take on new responsibilities, and build a path forward from wherever they begin.',
  },
  {
    title: 'Appreciation',
    body:
      'Employees\u2019 contributions are important to Shuert, and acknowledging those contributions is part of how we show appreciation. When possible, Shuert recognizes employees through team lunches, outings, gifts, and non-merit-based bonuses.',
  },
  {
    title: 'Open-Door Policy',
    body:
      'Every employee has direct access to management to share concerns, ask questions, and offer ideas. People should feel heard, respected, and comfortable bringing their perspective forward.',
  },
] as const;

const clubNames = [
  'Ethan Mercer',
  'Olivia Hart',
  'Mason Reed',
  'Charlotte Quinn',
  'Lucas Bennett',
  'Amelia Brooks',
  'Noah Sullivan',
  'Harper Ellis',
  'Jackson Cole',
  'Evelyn Foster',
  'Liam Turner',
  'Sophia Grant',
  'Caleb Dawson',
  'Nora Whitaker',
  'Owen Hayes',
  'Lily Morgan',
] as const;

const testimonials = [
  {
    name: 'Adam Rigg',
    role: 'JOB TITLE',
    avatar: avatarAdam,
    quote:
      'What I like most about working here is the opportunity to apply my industrial maintenance skills while continuing to learn and grow every day. I appreciate being part of an environment that challenges me to solve problems, improve equipment reliability, and develop new technical abilities. I\u2019m grateful for the experience, teamwork, and opportunities this job provides to expand my knowledge and contribute in a meaningful way.',
  },
  {
    name: 'Fawaaz Abdulmaged',
    role: 'JOB TITLE',
    avatar: avatarFawaaz1,
    quote:
      'I like the work environment the most. Everyone is supportive and respectful, and I\u2019ve learned a lot while working here. I also appreciate the teamwork and the opportunity to improve my skills every day.',
  },
  {
    name: 'Fawaaz Abdulmaged',
    role: 'JOB TITLE',
    avatar: avatarFawaaz2,
    quote:
      'Shuert is a good place to work because the team is supportive, the environment is positive, and there are good opportunities to learn and grow. I also appreciate the respect between employees and the focus on teamwork and quality work.',
  },
] as const;
---

<AboutLayout title="Careers" current="careers">
  <!-- ─────────── HERO ─────────── -->
  <section class="c-hero">
    <div class="c-hero__bg" aria-hidden="true">
      <img
        src={heroImg.src}
        alt=""
        class="c-hero__img"
        width={heroImg.width}
        height={heroImg.height}
        loading="eager"
        decoding="async"
      />
      <div class="c-hero__gradient"></div>
    </div>
    <div class="c-hero__content container">
      <div class="page-grid c-hero__grid">
        <div class="c-hero__left">
          <p class="c-hero__breadcrumb">
            <span class="c-hero__breadcrumb--dim">HOME&ensp;/&ensp;ABOUT&ensp;/&ensp;</span>CAREERS
          </p>
          <h1 class="detail-xl text-white">Careers</h1>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────── INTRO ─────────── -->
  <section class="careers-intro">
    <div class="container">
      <div class="page-grid careers-intro__grid">
        <div class="careers-intro__media">
          <img
            src={introImg.src}
            alt="Shuert team gathered on the production floor"
            width={introImg.width}
            height={introImg.height}
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="careers-intro__copy">
          <div class="careers-intro__text">
            <p>
              We&apos;re proud to be family-owned, but family has never been limited to ownership. At Shuert Technologies,
              family includes the people who have helped build our story — and who will carry it forward.
            </p>
            <p>
              That belief shapes how we lead, work, and support one another. To us, being family-oriented means creating a
              workplace where people know their contributions matter, their efforts are noticed, and their role is essential
              to the strength of the team. It shows up when we treat people with respect, recognize the value they bring, and
              take the time to know, support, and appreciate them — not just for what they do, but for who they are.
            </p>
          </div>
          <a class="button careers-intro__cta" href="/contact">Explore Openings</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────── WORKING AT SHUERT / ACCORDION ─────────── -->
  <section class="careers-culture">
    <div class="container">
      <div class="page-grid careers-culture__grid">
        <div class="careers-culture__left">
          <p class="label careers-section-label">OUR CULTURE</p>
          <h2 class="careers-h3">Working at Shuert</h2>

          <div class="careers-accordion" data-careers-accordion>
            {
              accordionItems.map((item, i) => (
                <div class="careers-accordion__item">
                  <button
                    type="button"
                    class="careers-accordion__trigger"
                    aria-expanded="false"
                    aria-controls={`careers-accordion-panel-${i}`}
                    id={`careers-accordion-trigger-${i}`}
                    data-accordion-trigger
                  >
                    <span class="careers-accordion__title">{item.title}</span>
                    <span class="careers-accordion__icon" aria-hidden="true" />
                  </button>
                  <div
                    class="careers-accordion__panel"
                    id={`careers-accordion-panel-${i}`}
                    role="region"
                    aria-labelledby={`careers-accordion-trigger-${i}`}
                    data-accordion-panel
                  >
                    <div class="careers-accordion__panel-inner">
                      <p class="careers-accordion__body">{item.body}</p>
                    </div>
                  </div>
                  {i < accordionItems.length - 1 && <div class="careers-accordion__rule" aria-hidden="true" />}
                </div>
              ))
            }
          </div>
        </div>

        <div class="careers-culture__media">
          <img
            src={cultureImg.src}
            alt=""
            width={cultureImg.width}
            height={cultureImg.height}
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────── 20 YEAR CLUB ─────────── -->
  <section class="careers-club" aria-labelledby="careers-club-heading">
    <div class="careers-club__fade careers-club__fade--top" aria-hidden="true"></div>
    <div class="careers-club__fade careers-club__fade--bottom" aria-hidden="true"></div>
    <div class="container careers-club__inner">
      <div class="page-grid careers-club__grid">
        <div class="careers-club__names" data-club-names aria-hidden="true">
          <div class="careers-club__track" data-club-track>
            {[...clubNames, ...clubNames].map((name) => (
              <p class="careers-club__name">{name}</p>
            ))}
          </div>
        </div>
        <div class="careers-club__copy">
          <h2 class="careers-club__heading" id="careers-club-heading">20 Year Club</h2>
          <p class="careers-club__text">
            Where people stay, contribute, and belong.<br />
            We appreciate what our employees accomplish<br />
            throughout their careers and believe long-term commitment is still worth building.
          </p>
        </div>
      </div>
    </div>
    <ul class="visually-hidden">
      {clubNames.map((name) => (
        <li>{name}</li>
      ))}
    </ul>
  </section>

  <!-- ─────────── TESTIMONIALS ─────────── -->
  <section class="careers-testimonials">
    <div class="container">
      <p class="label careers-section-label">TESTIMONIALS</p>
      <h2 class="careers-h3 careers-h3--sm">What Our Team Thinks</h2>
      <div class="page-grid careers-testimonials__grid">
        {
          testimonials.map((t) => (
            <article class="careers-testimonial">
              <img
                src={t.avatar.src}
                alt=""
                class="careers-testimonial__avatar"
                width={127}
                height={127}
                loading="lazy"
                decoding="async"
              />
              <h3>{t.name}</h3>
              <p class="careers-testimonial__role">{t.role}</p>
              <p class="careers-testimonial__text">{t.quote}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ─────────── REACH OUT ─────────── -->
  <section class="c-reach-out">
    <div class="container c-reach-out__inner">
      <div class="c-reach-out__grid">
        <div class="c-reach-out__content">
          <p class="label c-reach-out__eyebrow">REACH OUT</p>
          <h2 class="c-reach-out__title text-white">
            Stay in the loop on all<br />
            things Shuert, from product updates to exhibitions we&apos;re attending.
          </h2>
          <form class="c-reach-out__form" aria-label="Email updates">
            <div class="c-reach-out__field">
              <input
                type="email"
                class="c-reach-out__input"
                placeholder="Email Address"
                autocomplete="email"
                inputmode="email"
                aria-label="Email address"
              />
              <button type="submit" class="c-reach-out__submit">Submit</button>
            </div>
          </form>
        </div>
        <div class="c-reach-out__media">
          <img
            src={reachOutImg.src}
            alt="Forklift and stacked reusable pallets in a Shuert warehouse"
            class="c-reach-out__img"
            width={reachOutImg.width}
            height={reachOutImg.height}
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>
</AboutLayout>

<script>
  // Reach-out form (no-op submit)
  document.querySelector('.c-reach-out__form')?.addEventListener('submit', (e) => e.preventDefault());

  // Accordion — one panel open at a time; click open item to close
  (function () {
    const root = document.querySelector('[data-careers-accordion]');
    if (!root) return;

    const items = Array.from(root.querySelectorAll('.careers-accordion__item'));

    function setOpen(target) {
      items.forEach((item) => {
        const trigger = item.querySelector('[data-accordion-trigger]');
        const open = target !== null && item === target;
        item.classList.toggle('is-open', open);
        if (trigger instanceof HTMLButtonElement) {
          trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
        }
      });
    }

    items.forEach((item) => {
      const trigger = item.querySelector('[data-accordion-trigger]');
      trigger?.addEventListener('click', () => {
        if (item.classList.contains('is-open')) {
          setOpen(null);
          return;
        }
        setOpen(item);
      });
    });
  })();

  // 20 Year Club — continuous vertical marquee with random start
  (function () {
    const viewport = document.querySelector('[data-club-names]');
    const track = document.querySelector('[data-club-track]');
    if (!(viewport instanceof HTMLElement) || !(track instanceof HTMLElement)) return;

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const names = track.querySelectorAll('.careers-club__name');
    if (names.length < 2) return;

    const half = Math.floor(names.length / 2);
    const LINE = 56; // matches design line-height
    const loopH = LINE * half;

    // Random starting name on each page load
    const startIndex = Math.floor(Math.random() * half);
    let offset = startIndex * LINE;
    track.style.transform = `translate3d(0, ${-offset}px, 0)`;

    if (reduceMotion) return;

    const SPEED = 32; // px / sec
    let last = performance.now();
    let raf = 0;
    let running = false;

    function tick(now) {
      const dt = Math.min((now - last) / 1000, 0.064);
      last = now;
      offset += SPEED * dt;
      if (offset >= loopH) offset -= loopH;
      track.style.transform = `translate3d(0, ${-offset}px, 0)`;
      raf = requestAnimationFrame(tick);
    }

    function start() {
      if (running) return;
      running = true;
      last = performance.now();
      raf = requestAnimationFrame(tick);
    }

    function stop() {
      running = false;
      cancelAnimationFrame(raf);
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) start();
          else stop();
        });
      },
      { threshold: 0.05 },
    );
    io.observe(viewport);
  })();
</script>

<style>
  /* ================================================================
     HERO
     ================================================================ */
  .c-hero {
    position: relative;
    height: clamp(500px, 46.4vw, 802px);
    overflow: hidden;
    background: var(--c-black);
  }

  .c-hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .c-hero__img {
    position: absolute;
    width: 100%;
    height: 121.2%;
    top: 0;
    left: 0;
    max-width: none;
    object-fit: cover;
  }

  .c-hero__gradient {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0) 63.12%, rgb(0 0 0) 88.95%),
      linear-gradient(0deg, rgba(0, 0, 0, 0) 64.59%, rgb(0 0 0) 100%);
  }

  .c-hero__content {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    align-items: flex-end;
    padding-bottom: clamp(1.5rem, 3.18vw, 55px);
  }

  .c-hero__grid {
    align-items: end;
    width: 100%;
  }

  .c-hero__left {
    grid-column: 1 / 9;
  }

  .c-hero__breadcrumb {
    margin: 0 0 29px;
    font: var(--w-bold) 12px / 12px var(--ff-s);
    letter-spacing: 1.32px;
    text-transform: uppercase;
    color: var(--c-white);
  }

  .c-hero__breadcrumb--dim {
    color: rgba(255, 255, 255, 0.35);
  }

  .c-hero__left .detail-xl {
    margin: 0;
  }

  /* ================================================================
     INTRO
     ================================================================ */
  .careers-intro {
    background: var(--c-sec-1);
    border-top: 1px solid #e3ded6;
    padding: 77px 0 150px;
  }

  .careers-intro__grid {
    align-items: center;
  }

  .careers-intro__media {
    grid-column: 1 / 8;
    border-radius: 14px;
    overflow: hidden;
    aspect-ratio: 924 / 662;
  }

  .careers-intro__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .careers-intro__copy {
    grid-column: 9 / -1;
    display: flex;
    flex-direction: column;
    gap: 35px;
    align-items: flex-start;
    max-width: 519px;
  }

  .careers-intro__text {
    display: flex;
    flex-direction: column;
    gap: 1.375rem;
  }

  .careers-intro__text p {
    margin: 0;
    font: var(--w-light) 16px / 22px var(--ff-r);
    color: var(--c-black);
  }

  .careers-intro__cta {
    display: inline-flex;
    background: var(--c-black);
    color: var(--c-white);
    border-color: transparent;
    text-decoration: none;
  }

  .careers-intro__cta:hover {
    opacity: 0.92;
  }

  /* ================================================================
     CULTURE + ACCORDION
     ================================================================ */
  .careers-culture {
    background: var(--c-sec-1);
    padding: 0 0 150px;
  }

  .careers-section-label {
    margin: 0;
    color: var(--c-sec-3);
    letter-spacing: 1.54px;
  }

  .careers-h3 {
    margin: 15px 0 0;
    font: var(--w-medium) 30px / 33px var(--ff-r);
    color: var(--c-black);
  }

  .careers-h3--sm {
    margin-top: 15px;
  }

  .careers-culture__grid {
    align-items: start;
  }

  .careers-culture__left {
    grid-column: 1 / 7;
    max-width: 731px;
  }

  .careers-culture__media {
    grid-column: 7 / -1;
    justify-self: end;
    width: 100%;
    max-width: 789px;
    aspect-ratio: 1;
    border-radius: 14px;
    overflow: hidden;
    margin-top: 62px;
  }

  .careers-culture__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .careers-accordion {
    margin-top: clamp(2.5rem, 11.4vw, 197px);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .careers-accordion__item {
    display: flex;
    flex-direction: column;
  }

  .careers-accordion__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    width: 100%;
    min-height: 40px;
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    text-align: left;
  }

  .careers-accordion__title {
    font: var(--w-light) 20px / 26px var(--ff-r);
    color: var(--c-black);
    opacity: 0.2;
    transition: opacity 0.3s ease;
  }

  .careers-accordion__item.is-open .careers-accordion__title {
    opacity: 1;
  }

  .careers-accordion__icon {
    position: relative;
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 41px;
    background: #efece7;
  }

  .careers-accordion__icon::before,
  .careers-accordion__icon::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 50%;
    background: var(--c-black);
    transform: translate(-50%, -50%);
  }

  /* horizontal bar (always) */
  .careers-accordion__icon::before {
    width: 12px;
    height: 1px;
  }

  /* vertical bar → plus when closed */
  .careers-accordion__icon::after {
    width: 1px;
    height: 12px;
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .careers-accordion__item.is-open .careers-accordion__icon::after {
    opacity: 0;
  }

  .careers-accordion__panel {
    display: grid;
    grid-template-rows: 0fr;
    max-width: 648px;
    transition: grid-template-rows 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .careers-accordion__item.is-open .careers-accordion__panel {
    grid-template-rows: 1fr;
  }

  .careers-accordion__panel-inner {
    overflow: hidden;
    min-height: 0;
  }

  .careers-accordion__body {
    margin: 0;
    padding-top: 12px;
    font: var(--w-light) 16px / 22px var(--ff-r);
    color: var(--c-black);
    opacity: 0;
    transform: translateY(-4px);
    transition:
      opacity 0.3s ease 0.05s,
      transform 0.35s cubic-bezier(0.32, 0.72, 0, 1) 0.05s;
  }

  .careers-accordion__item.is-open .careers-accordion__body {
    opacity: 1;
    transform: translateY(0);
  }

  .careers-accordion__rule {
    width: 100%;
    height: 0;
    margin-top: 12px;
    border-top: 1px solid #d4cec6;
  }

  .careers-accordion__trigger:focus-visible {
    outline: 2px solid var(--c-black);
    outline-offset: 4px;
    border-radius: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    .careers-accordion__panel,
    .careers-accordion__body,
    .careers-accordion__title,
    .careers-accordion__icon::after {
      transition: none;
    }
  }

  /* ================================================================
     20 YEAR CLUB
     ================================================================ */
  .careers-club {
    position: relative;
    background: #efece7;
    height: 824px;
    overflow: hidden;
  }

  .careers-club__fade {
    position: absolute;
    left: 0;
    right: 0;
    height: 824px;
    z-index: 2;
    pointer-events: none;
  }

  .careers-club__fade--top {
    top: 0;
    background: linear-gradient(180deg, #efece7 5%, rgba(239, 236, 231, 0) 40%);
  }

  .careers-club__fade--bottom {
    bottom: 0;
    background: linear-gradient(0deg, #efece7 5%, rgba(239, 236, 231, 0) 40%);
  }

  .careers-club__inner {
    position: relative;
    z-index: 1;
    height: 100%;
  }

  .careers-club__grid {
    height: 100%;
    align-items: center;
  }

  .careers-club__names {
    grid-column: 2 / 6;
    height: 100%;
    overflow: hidden;
    mask-image: linear-gradient(180deg, transparent 0%, #000 18%, #000 82%, transparent 100%);
    -webkit-mask-image: linear-gradient(180deg, transparent 0%, #000 18%, #000 82%, transparent 100%);
  }

  .careers-club__track {
    will-change: transform;
  }

  .careers-club__name {
    margin: 0;
    font: var(--w-medium) 48px / 56px var(--ff-r);
    color: var(--c-black);
    white-space: nowrap;
  }

  .careers-club__copy {
    grid-column: 7 / 11;
    max-width: 556px;
    display: flex;
    flex-direction: column;
    gap: 35px;
  }

  .careers-club__heading {
    margin: 0;
    font: var(--w-semibold) 40px / 43px var(--ff-s);
    color: var(--c-black);
  }

  .careers-club__text {
    margin: 0;
    font: var(--w-light) 25px / 32px var(--ff-r);
    color: var(--c-black);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ================================================================
     TESTIMONIALS
     ================================================================ */
  .careers-testimonials {
    background: var(--c-sec-1);
    padding: 150px 0 96px;
  }

  .careers-testimonials__grid {
    margin-top: 84px;
    gap: 28px 20px;
  }

  .careers-testimonial {
    grid-column: span 4;
  }

  .careers-testimonial__avatar {
    width: 127px;
    height: 127px;
    border-radius: 50%;
    object-fit: cover;
    margin-bottom: 28px;
    display: block;
  }

  .careers-testimonial h3 {
    margin: 0;
