---
import Mainlayout from '../../layouts/Mainlayout.astro';
import MultiSelect from '../../components/MultiSelect.astro';
import { PRODUCT_OPTIONS } from '../../data/formOptions';
import heroImg from '../../assets/product/index/064607540992bca96b018e8895ceb73ab9b9f54d.png';
import uniPakImg from '../../assets/product/index/6324929b6ffd966af7a2778ee189f60b599310e9.png';
import uniDirPalletImg from '../../assets/product/index/7ff131f8858a7b66c45784b5edc74c3a71e37ef2.png';
import remanImg from '../../assets/product/index/3028050f466102f5296e21bd8f008072f3e5416e.png';
import uniPalletImg from '../../assets/product/index/aa4c71cf6fd121cfe04e6f4f44658228fc24d3dc.png';
import snapPakImg from '../../assets/product/index/7afa23b4d9678b5221bedf3bb5d58d68f36943e3.png';
import batteryRakImg from '../../assets/product/index/4b9afdab783164ce504f12728e64bcfb848d21d2.png';
import bulkPakImg from '../../assets/product/index/fcd48ab930f8cb18118377413ddb31102fbf6a8b.png';
import yarnPakImg from '../../assets/product/index/e9c3bad29049bc104caa12c3c1df6a909ac3c3d7.png';
import axlePakImg from '../../assets/product/index/56e5e0488ca1226ecb15ba61951c49ae13582380.png';
import batteryShellImg from '../../assets/product/index/a2fba7307a268376e5965c15eed34f5f050db60e.png';
import proPakImg from '../../assets/product/index/962bc5dea41b9cb8605e747bfd0c533ce2a929fa.png';
import exairPalletImg from '../../assets/product/index/6d491e071fc9a0e187d505a9422887387b2911e8.png';
import uniPalletDoublerImg from '../../assets/product/index/ec9f80a540e1500371c3f3ed38b78e62b9077848.png';
import sleevesImg from '../../assets/product/index/aa41e80d3b854437febc89d1bbb40ed82f5d740c.png';
import uniCaseImg from '../../assets/product/index/454084480a055ddddae249d65a9d63552f1b760d.png';
import uniRakImg from '../../assets/product/index/64c1ebff21662b97d2badc576764e2beb665d3d0.png';
import perimeterBaseImg from '../../assets/product/index/ace628f106d3945cb72725dcdea147e2c7a6eff4.png';
import modulePakImg from '../../assets/product/index/8a3ddf1c3913dddbff2427e7e435308c4d616728.png';
import terraRoadImg from '../../assets/product/index/c25cf16ea6bf49b562af48467ba1e375c9120fbb.png';
import uniPakIiImg from '../../assets/product/index/1f33178a0228a5eee17d27db2787893e839ba77b.png';
import customImg from '../../assets/product/index/5b12aa8d3d5dc5bb61774bd04c5ab8c85dbb0152.png';
import quoteImg from '../../assets/product/index/60c26e97b304b786a121896cb8a9ba9c10e748e0.png';

const sizeRange = '29” x 23”  —  90” x 48”';
const sizePallet = '48” x 78” x 36”';

const products = [
  { name: 'uni-pak', size: sizeRange, image: uniPakImg, href: '/products/unipak' },
  { name: 'uni-directional pallet', size: sizePallet, image: uniDirPalletImg, href: '/products/uni-directional-pallet' },
  { name: 'remanufacturing-systems', size: 'Systems for Remanufacturing Drivetrain Components', image: remanImg, href: '/products/reman-pak' },
  { name: 'uni-pallet', size: sizeRange, image: uniPalletImg, href: '/products/uni-pallet' },
  { name: 'snap-pak', size: sizePallet, image: snapPakImg, href: '#' },
  { name: 'battery-rak', size: sizePallet, image: batteryRakImg, href: '/products/battery-pak', crop: 'battery-rak' },
  { name: 'bulk-pak', size: sizeRange, image: bulkPakImg, href: '/products/bulk-pak' },
  { name: 'yarn-pak', size: sizeRange, image: yarnPakImg, href: '/products/yarn-pak' },
  { name: 'axle-pak', size: sizeRange, image: axlePakImg, href: '#' },
  { name: 'battery-shell', size: sizeRange, image: batteryShellImg, href: '#' },
  { name: 'pro-pak', size: sizeRange, image: proPakImg, href: '/products/pro-pak' },
  { name: 'exair-pallet', size: sizeRange, image: exairPalletImg, href: '#' },
  { name: 'uni-pallet doubler', size: sizeRange, image: uniPalletDoublerImg, href: '#' },
  { name: 'sleeves', size: 'Request More Information', image: sleevesImg, href: '#' },
  { name: 'uni-case', size: sizeRange, image: uniCaseImg, href: '/products/uni-case' },
  { name: 'uni-rak', size: sizeRange, image: uniRakImg, href: '/products/uni-rak' },
  { name: 'perimeter-base pallet', size: sizeRange, image: perimeterBaseImg, href: '#' },
  { name: 'module-pak', size: sizeRange, image: modulePakImg, href: '#' },
  { name: 'terra-road', size: sizeRange, image: terraRoadImg, href: '#' },
  { name: 'uni-pak II', size: sizeRange, image: uniPakIiImg, href: '/products/unipak' },
  { name: 'custom', size: sizeRange, image: customImg, href: '/products/custom' },
];

const filters = [
  { label: 'Product' },
  { label: 'Market' },
  { label: 'Size' },
];
---

<Mainlayout title="Products">
  <!-- Hero -->
  <section class="p-hero">
    <div class="p-hero__bg" aria-hidden="true">
      <img
        src={heroImg.src}
        alt=""
        class="p-hero__img"
        width={heroImg.width}
        height={heroImg.height}
        loading="eager"
        decoding="async"
      />
      <div class="p-hero__gradient"></div>
    </div>
    <div class="p-hero__content container">
      <div class="page-grid p-hero__grid">
        <div class="p-hero__left">
          <p class="p-hero__breadcrumb">
            <span class="p-hero__breadcrumb--dim">HOME&ensp;/&ensp;</span>ALL PRODUCTS
          </p>
          <h1 class="detail-xl text-white">products</h1>
        </div>
        <div class="p-hero__right">
          <p class="p-hero__desc text-white">
            Lorem ipsum dolor sit amet consectetur. Donec gravida quam sit consequat eget dignissim. Tristique nibh tristique cum purus dictumst nec lorem magnis. Sed dolor odio arcu magna pellentesque sem.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="products-body">
    <!-- Filters -->
    <section class="p-filters">
      <div class="container">
        <div class="p-filters__bar">
          <div class="p-filters__scroll">
            <div class="p-filters__buttons">
              {filters.map((filter) => (
                <button class="p-filters__btn" type="button">
                  <span>{filter.label}</span>
                  <svg class="p-filters__chevron" width="10" height="20" viewBox="0 0 10 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M0.35 10L5 14.66L9.67 10" stroke="currentColor"/>
                  </svg>
                </button>
              ))}
            </div>
          </div>
          <div class="p-filters__actions">
            <button class="p-filters__badge-btn" type="button" aria-label="3 active filters">
              <span class="p-filters__badge-dot">3</span>
            </button>
            <button class="p-filters__reset" type="button">Reset Filters</button>
          </div>
        </div>
      </div>
    </section>

    <!-- Product Grid -->
    <section class="p-grid">
      <div class="container">
        <div class="p-grid__cells">
          {products.map((product) => (
            <a class="p-card" href={product.href}>
              <div class:list={['p-card__img', { 'p-card__img--battery-rak': product.crop === 'battery-rak' }]}>
                <img
                  src={product.image.src}
                  alt={product.name}
                  width={product.image.width}
                  height={product.image.height}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="p-card__info">
                <h3 class="p-card__name">{product.name}</h3>
                <p class="p-card__size">{product.size}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </div>

  <!-- Request a Quote -->
  <section class="p-quote">
    <div class="container">
      <div class="p-quote__layout">
        <div class="p-quote__form-side">
          <p class="p-quote__eyebrow label">REQUEST A QUOTE</p>
          <h2 class="p-quote__title text-white">
            Lorem ipsum dolor sit amet consectetur. Enim egestas elementum auctor cursus semper maecenas ipsum risus neque.
          </h2>
          <form class="p-quote__form" aria-label="Request a quote">
            <div class="p-quote__row p-quote__row--half">
              <div class="p-quote__field">
                <label class="p-quote__label">FIRST NAME</label>
                <input type="text" class="p-quote__input" placeholder="First" />
              </div>
              <div class="p-quote__field">
                <label class="p-quote__label">LAST NAME</label>
                <input type="text" class="p-quote__input" placeholder="Last" />
              </div>
            </div>
            <div class="p-quote__field">
              <label class="p-quote__label">COMPANY NAME</label>
              <input type="text" class="p-quote__input" placeholder="Company" />
            </div>
            <div class="p-quote__field">
              <label class="p-quote__label">EMAIL</label>
              <input type="email" class="p-quote__input" placeholder="Email" />
            </div>
            <div class="p-quote__row p-quote__row--half">
              <div class="p-quote__field">
                <label class="p-quote__label">PHONE</label>
                <input type="tel" class="p-quote__input" placeholder="Phone" />
              </div>
              <div class="p-quote__field">
                <label class="p-quote__label">QUANTITY</label>
                <input type="text" class="p-quote__input" placeholder="Quantity" />
              </div>
            </div>
            <div class="p-quote__field">
              <label class="p-quote__label" for="products-of-interest">PRODUCTS OF INTEREST</label>
              <MultiSelect
                id="products-of-interest"
                name="productsOfInterest"
                options={PRODUCT_OPTIONS}
                placeholder="Select products…"
              />
            </div>
            <div class="p-quote__field">
              <label class="p-quote__label">ANY OTHER QUESTIONS?</label>
              <textarea class="p-quote__input p-quote__textarea" placeholder="Additional Info"></textarea>
            </div>
            <button type="submit" class="p-quote__submit">Submit</button>
          </form>
        </div>
        <div class="p-quote__media">
          <img
            src={quoteImg.src}
            alt="Forklift and stacked reusable pallets in a Shuert warehouse"
            class="p-quote__img"
            width={quoteImg.width}
            height={quoteImg.height}
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>
</Mainlayout>

<script>
  const form = document.querySelector('.p-quote__form');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
  });
</script>

<style>
  /* ================================================================
     HERO
     ================================================================ */
  .p-hero {
    position: relative;
    height: clamp(500px, 46.4vw, 802px);
    overflow: hidden;
    background: var(--c-black);
  }

  .p-hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .p-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
  }

  .p-hero__gradient {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(0,0,0,0) 75.13%, rgb(0,0,0) 100%),
      linear-gradient(0deg, rgba(0,0,0,0) 53.11%, rgb(0,0,0) 100%);
  }

  .p-hero__content {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    align-items: flex-end;
    padding-bottom: clamp(1.5rem, 3.18vw, 55px);
  }

  .p-hero__grid {
    align-items: end;
    width: 100%;
  }

  .p-hero__left {
    grid-column: 1 / 9;
  }

  .p-hero__breadcrumb {
    margin: 0 0 29px;
    font: var(--w-bold) 12px / 12px var(--ff-s);
    letter-spacing: 1.32px;
    text-transform: uppercase;
    color: var(--c-white);
  }

  .p-hero__breadcrumb--dim {
    color: rgba(255, 255, 255, 0.35);
  }

  .p-hero__left .detail-xl {
    margin: 0;
  }

  .p-hero__right {
    grid-column: 9 / -1;
  }

  .p-hero__desc {
    margin: 0;
    font: var(--w-light) 16px / 22px var(--ff-r);
    max-width: 520px;
  }

  /* ================================================================
     PRODUCTS BODY (cream background wrapper)
     ================================================================ */
  .products-body {
    background: var(--c-sec-1);
    padding-bottom: clamp(3rem, 6.5vw, 112px);
  }

  /* ================================================================
     FILTERS
     ================================================================ */
  .p-filters {
    padding-top: clamp(2rem, 3.5vw, 61px);
  }

  .p-filters__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 8px;
    background: rgba(237, 234, 230, 0.5);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    border-radius: 14px;
  }

  .p-filters__scroll {
    flex: 1;
    min-width: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .p-filters__scroll::-webkit-scrollbar {
    display: none;
  }

  .p-filters__buttons {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .p-filters__btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 15px 18px;
    background: #edeae6;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font: var(--w-medium) 16px / normal var(--ff-r);
    color: var(--c-black);
    white-space: nowrap;
    transition: background 0.2s, color 0.2s;
  }

  .p-filters__btn:hover {
    background: #e0dcd7;
  }

  .p-filters__chevron {
    flex-shrink: 0;
    width: 10px;
    height: 20px;
  }

  .p-filters__actions {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .p-filters__badge-btn {
    position: relative;
    width: 50px;
    height: 50px;
    background: #edeae6;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .p-filters__badge-dot {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 21px;
    height: 21px;
    border-radius: 50%;
    background: #d92136;
    color: var(--c-white);
    font: var(--w-bold) 12px / 1 var(--ff-r);
  }

  .p-filters__reset {
    padding: 15px 18px;
    background: #edeae6;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font: var(--w-medium) 16px / normal var(--ff-r);
    color: var(--c-black);
    white-space: nowrap;
    transition: background 0.2s;
  }

  .p-filters__reset:hover {
    background: #e0dcd7;
  }

  /* ================================================================
     PRODUCT GRID
     ================================================================ */
  .p-grid {
    padding-top: clamp(2.5rem, 4.5vw, 77px);
  }

  .p-grid__cells {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .p-card {
    display: flex;
    flex-direction: column;
    aspect-ratio: 530 / 613;
    text-decoration: none;
    color: inherit;
    border-right: 2px solid #ebe7e3;
    border-bottom: 2px solid #ebe7e3;
    overflow: hidden;
  }

  .p-card:nth-child(3n) {
    border-right: none;
  }

  .p-card:nth-last-child(-n + 3) {
    border-bottom: none;
  }

  .p-card__img {
    flex: 538;
    min-height: 0;
    overflow: hidden;
    position: relative;
  }

  .p-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .p-card__img--battery-rak img {
    position: absolute;
    width: 226.72%;
    height: 227.14%;
    max-width: none;
    left: -28.39%;
    top: -63.57%;
    object-fit: cover;
  }

  .p-card:hover .p-card__img img {
    transform: scale(1.04);
  }

  .p-card:hover .p-card__img--battery-rak img {
    transform: none;
  }

  .p-card__info {
    flex: 75;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
    padding: 0 10px;
  }

  .p-card__name {
    margin: 0;
    font: var(--w-semibold) clamp(1.25rem, 1.8vw, 30px) / 32px var(--ff-s);
    letter-spacing: -0.75px;
    text-transform: lowercase;
    white-space: nowrap;
  }

  .p-card__size {
    margin: 9px 0 0;
    font: var(--w-light) 16px / 22px var(--ff-r);
    color: var(--c-black);
    white-space: nowrap;
  }

  /* ================================================================
     REQUEST A QUOTE
     ================================================================ */
  .p-quote {
    background: #1b1b1b;
    padding: clamp(3rem, 4.8vw, 83px) 0 clamp(3rem, 4.2vw, 73px);
  }

  .p-quote__layout {
    display: grid;
    align-items: start;
  }

  .p-quote__eyebrow {
    margin: 0 0 31px;
    color: var(--c-white);
    letter-spacing: 1.54px;
  }

  .p-quote__title {
    margin: 0 0 59px;
    max-width: 654px;
    font: var(--w-semibold) clamp(1.5rem, 1.8vw, 30px) / 33px var(--ff-r);
  }

  .p-quote__form {
    display: flex;
    flex-direction: column;
    gap: 23px;
  }

  .p-quote__row--half {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .p-quote__label {
    display: block;
    margin-bottom: 14px;
    font: var(--w-bold) 14px / 14px var(--ff-s);
    letter-spacing: 1.54px;
    text-transform: uppercase;
    color: var(--c-white);
  }

  .p-quote__input {
    display: block;
    width: 100%;
    height: 44px;
    padding: 0 18px;
    background: var(--c-black);
    border: none;
    border-radius: 8px;
    color: var(--c-white);
    font: 400 16px / 22px var(--ff-r);
    outline: none;
    box-sizing: border-box;
  }

  .p-quote__input:focus {
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.2);
  }

  .p-quote__input::placeholder {
    color: rgba(255, 255, 255, 0.36);
  }

  .p-quote__textarea {
    height: 106px;
    padding: 18px;
    resize: none;
  }

  .p-quote__submit {
    align-self: flex-start;
    padding: 15px 18px;
    background: var(--c-black);
    border: none;
    border-radius: 8px;
    color: var(--c-white);
    font: var(--w-medium) 16px / normal var(--ff-r);
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .p-quote__submit:hover {
    opacity: 0.85;
  }

  .p-quote__submit:focus-visible {
    outline: 2px solid var(--c-white);
    outline-offset: 2px;
  }

  .p-quote__media {
    border-radius: 14px;
    overflow: hidden;
    margin-top: -17px;
  }

  .p-quote__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ================================================================
     DESKTOP LAYOUT (≥ 1728px)
     ================================================================ */
  @media (min-width: 1728px) {
    .p-quote__layout {
      grid-template-columns: 695px 789px;
      column-gap: 114px;
    }

    .p-quote__media {
      width: 789px;
      max-width: none;
      aspect-ratio: 789 / 908;
    }
  }

  /* ================================================================
     WIDE DESKTOP (1025px – 1727px)
     ================================================================ */
  @media (min-width: 64.01rem) and (max-width: 1727px) {
    .p-quote__layout {
      grid-template-columns: minmax(0, 695fr) minmax(0, 789fr);
      column-gap: clamp(2rem, 7vw, 114px);
    }

    .p-quote__media {
      aspect-ratio: 789 / 908;
    }
  }

  /* ================================================================
     TABLET (≤ 1024px)
     ================================================================ */
  @media (max-width: 64rem) {
    .p-hero {
      height: clamp(420px, 55vw, 640px);
    }

    .p-hero__left {
      grid-column: 1 / -1;
      padding-bottom: 0;
    }

    .p-hero__right {
      grid-column: 1 / -1;
      margin-top: 1.25rem;
    }

    .p-hero__desc {
      max-width: none;
    }

    .p-grid__cells {
      grid-template-columns: repeat(2, 1fr);
    }

    .p-card:nth-child(3n) {
      border-right: 2px solid #ebe7e3;
    }

    .p-card:nth-child(2n) {
      border-right: none;
    }

    .p-card:nth-last-child(-n + 3) {
      border-bottom: 2px solid #ebe7e3;
    }

    .p-card:nth-last-child(-n + 2) {
      border-bottom: none;
    }

    .p-card__name,
    .p-card__size {
      white-space: normal;
    }

    .p-quote__layout {
      grid-template-columns: 1fr;
      row-gap: 2.5rem;
    }

    .p-quote__media {
      margin-top: 0;
      max-width: 600px;
      aspect-ratio: 789 / 908;
    }

    .p-quote__title {
      margin-bottom: 2rem;
    }
  }

  /* ================================================================
     MOBILE (≤ 768px)
     ================================================================ */
  @media (max-width: 48rem) {
    .p-hero {
      height: clamp(360px, 80vw, 500px);
    }

    .p-grid__cells {
      grid-template-columns: 1fr;
    }

    .p-card {
      border-right: none !important;
      aspect-ratio: auto;
    }

    .p-card:nth-last-child(-n + 3) {
      border-bottom: 2px solid #ebe7e3;
    }

    .p-card:last-child {
      border-bottom: none;
    }

    .p-card__img {
      aspect-ratio: 530 / 538;
    }

    .p-card__info {
      padding: 18px 10px 32px;
    }

    .p-card__name {
      text-align: center;
    }

    .p-filters__actions {
      display: none;
    }

    .p-quote__row--half {
      grid-template-columns: 1fr;
    }

    .p-quote__form {
      gap: 18px;
    }
  }
</style>
