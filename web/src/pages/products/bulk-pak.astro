---
import Mainlayout from '../../layouts/Mainlayout.astro';

// Hero
import headerBg from '../../assets/product/bulkpak/259c9bdcdb238c1771dea7de9b2929304415730b.png';
import productMain from '../../assets/product/bulkpak/fcd48ab930f8cb18118377413ddb31102fbf6a8b.png';
import thumb2 from '../../assets/product/bulkpak/58f62c3211f617be370d1308b95b96a04c4d49f2.png';
import thumb3 from '../../assets/product/bulkpak/ee85d38ea644974f53a0ee1be60350167d1aeaeb.png';
import thumb4 from '../../assets/product/bulkpak/e99f7092f3bc7644f4af943bdfd66ecbb45be0c4.png';
import regMark from '../../assets/product/bulkpak/403b6db3da16d106b5aa34a84d31b84964a0c318.svg?url';
import arrowLeft from '../../assets/product/bulkpak/abff48ce9e906836ba7c7455b9bcb761cb081819.svg?url';
import arrowRight from '../../assets/product/bulkpak/ace057969575dd73641ee7d72883898b53d3fbbb.svg?url';
import downloadIcon from '../../assets/product/bulkpak/70353c936ccd078ce845eb18bc2986a95f96449d.svg?url';

// Technical features carousel
import featCastle from '../../assets/product/bulkpak/d280539f1e956a7dca9fab036dd9648ff1e73d44.png';
import featRackable from '../../assets/product/bulkpak/904864a78cdf36ac4c53e34723ae669024ba953e.png';
import featFlowable from '../../assets/product/bulkpak/c55653fe1ed43409c4faeccbf02cb5344e07dbf5.png';
import featSlide from '../../assets/product/bulkpak/dc99178ae2ca5ece0c57995b2143ffeb06509eec.png';
import featTwin from '../../assets/product/bulkpak/12f92938ad4da8853a6ddcd6594f98d47cabb7f6.png';

// Proven in the field logos
import logoAmazon from '../../assets/product/bulkpak/02f92f6d22d008d15ced403e5b2f35f182438c7e.svg?url';
import logoCocaCola from '../../assets/product/bulkpak/b4b0c594f7a8ce5d9c3ad2ece874f00f27e0b099.svg?url';
import logoTesla from '../../assets/product/bulkpak/6af663dec056d2db87f1f6019b8799995a77db59.svg?url';

// Markets
import marketAuto from '../../assets/product/bulkpak/69c891b2aca4ffc8464f7fade40f9f22cb5f3137.png';
import marketFmcg from '../../assets/product/bulkpak/d2b7b887297f6112c7c91b004f49ae9dd4153efe.png';
import marketAutomation from '../../assets/product/bulkpak/faee7a1bbe05c82ec1462f3dd77c86525e27666a.png';

// Logistics
import truck from '../../assets/product/bulkpak/18a2bdb895df8c9d2c24a3b0051138826bd1a79c.png';

// Specs wordmark
import uniPakWordmark from '../../assets/product/bulkpak/365718496e1bee9db1886c91fe227df090029176.svg?url';

// Related products
import relatedImg from '../../assets/product/bulkpak/cb92ee5b1e8e00c11df46aa095fe04df48b93143.png';

// Request a quote
import quoteImg from '../../assets/product/bulkpak/60c26e97b304b786a121896cb8a9ba9c10e748e0.png';

const aboutText =
  'The most sustainable, versatile, durable, and cost-effective closed-loop material handling system on the market. Each Uni-Pak is built to last, with a ten-year life expectancy, hundreds of trips, and can be fully recycled at the end of its life. Designed to be space-efficient, ergonomic, and strong, it lowers total ownership costs while offering a customizable solution for your unique shipping needs.';

const thumbnails = [
  { img: productMain, alt: 'Bulk-Pak product view 1' },
  { img: thumb2, alt: 'Bulk-Pak product view 2' },
  { img: thumb3, alt: 'Bulk-Pak product view 3' },
  { img: thumb4, alt: 'Bulk-Pak product view 4' },
];

const features = [
  { tag: 'Castle Sleeve', img: featCastle, desc: 'Uni-Pak pallet is available with optional drain holes in the legs.' },
  { tag: 'Rackable', img: featRackable, desc: 'Added knitting between the thermoformed layers for added durability.' },
  { tag: 'Flowable', img: featFlowable, desc: 'Lid is secured to the sleeve via four injection-molded slide locks, ensuring a tight, reliable closure throughout the supply chain.' },
  { tag: 'Slide Locks', img: featSlide, desc: 'Lid is secured to the sleeve via four injection-molded slide locks, ensuring a tight, reliable closure throughout the supply chain.' },
  { tag: 'Twin Sheet Thermoformed Plastic', img: featTwin, desc: 'Small blurb about the specific capability.' },
] as const;

const FEATURES_AUTOPLAY_MS = 3000;
const firstFeature = features[0];
const lastFeature = features[features.length - 1];

const proven = [
  {
    logo: logoAmazon,
    logoAlt: 'Amazon',
    logoW: 135,
    logoH: 41,
    title: 'Sustainable Shipping',
    desc: 'Lorem ipsum dolor sit amet consectetur. Diam aliquam nulla pellentesque blandit. Justo proin elit vel sagittis sodales dui sed. Enim tincidunt ipsum arcu ut sit nibh dolor magna. Lobortis amet orci faucibus risus. Bibendum cursus cursus elementum adipiscing arcu aliquam leo posuere non. A sit quam convallis laoreet. Donec purus purus nec ornare facilisis turpis ultricies dui vestibulum. Quisque felis nec morbi odio dui sapien.',
  },
  {
    logo: logoCocaCola,
    logoAlt: 'Coca-Cola',
    logoW: 135,
    logoH: 41,
    title: 'Custom and Durable',
    desc: 'Lorem ipsum dolor sit amet consectetur. Eget a sit massa dui pellentesque sodales ornare. Vivamus eget tellus parturient sodales. Leo amet volutpat suscipit natoque congue blandit massa adipiscing. Id amet suspendisse vel tincidunt semper sit. Adipiscing arcu volutpat tincidunt vitae tempor eget dolor. Tristique sollicitudin in vestibulum luctus. Sit neque nunc et morbi vel pharetra dui suspendisse. Malesuada pharetra sit sed tellus scelerisque mattis. Natoque a volutpat fermentum nullam viverra nam.',
  },
  {
    logo: logoTesla,
    logoAlt: 'Tesla',
    logoW: 135,
    logoH: 18,
    title: 'Large but Light',
    desc: 'Lorem ipsum dolor sit amet consectetur. Lorem elit donec egestas pellentesque tincidunt. Venenatis lectus quis pulvinar nunc in at et lorem. Purus rhoncus consectetur auctor volutpat dui posuere felis aliquet. Suspendisse ut varius et placerat semper amet. At posuere congue tellus porta aliquet odio.',
  },
];

const marketsDesc =
  'Lorem ipsum dolor sit amet consectetur. Ut purus non urna sagittis scelerisque eu. Sem a amet viverra lectus egestas sed nibh amet facilisis. Tincidunt ullamcorper vulputate id nisi ut massa. Blandit pharetra a nibh nunc arcu.';

const markets = [
  { label: 'Automotive', img: marketAuto, desc: marketsDesc },
  { label: 'Mast Moving Consumer Goods', img: marketFmcg, desc: marketsDesc },
  { label: 'Automation', img: marketAutomation, desc: marketsDesc },
];

const related = [
  { name: 'snap-pak', size: '29”x23”  —  90”x48”', img: relatedImg },
  { name: 'uni-pak', size: '29”x23”  —  90”x48”', img: relatedImg },
  { name: 'uni-pak', size: '29”x23”  —  90”x48”', img: relatedImg },
];

// Specs table
const specColGroups = ['ERECT', 'COLLAPSED (NO KIT)', 'RETURN RATIO'];
const specCols = ['OD DIM.', 'MARKET', 'ID LENGTH', 'ID WIDTH', 'PAL WT.', 'COV WT.'];
const firstRow = ['29 x 23', 'NA', '26.94', '20.94', '6.88', '4.68', '168', '252', '528', '570', '1/3.1', '1/2.3'];
const naRow = ['29 x 23', 'NA', 'NA', 'NA', 'NA', 'NA', 'NA', 'NA', 'NA', 'NA', 'NA', 'NA'];
const specRows = [firstRow, ...Array.from({ length: 16 }, () => naRow)];
---

<Mainlayout title="Bulk-Pak" mainClass="bp">
  <!-- ============================== HERO HEADER ============================== -->
  <section class="bp-header">
    <div class="bp-header__bg" aria-hidden="true">
      <img
        src={headerBg.src}
        alt=""
        width={headerBg.width}
        height={headerBg.height}
        class="bp-header__img"
        loading="eager"
        decoding="async"
      />
      <div class="bp-header__gradient"></div>
    </div>
    <div class="container bp-header__inner">
      <p class="bp-header__crumb">
        <span class="bp-header__crumb-dim">HOME&ensp;/&ensp;ALL PRODUCTS&ensp;/&ensp;</span>BULK-PAK
      </p>
      <h1 class="bp-header__title detail-xl text-white">
        bulk-pak<img src={regMark} alt="" class="bp-header__reg" width="18" height="23" />
      </h1>

      <div class="bp-header__meta">
        <span class="bp-header__dims">48”x40” &amp; 48”x45”</span>
        <div class="bp-toggle" role="group" aria-label="Unit system">
          <button type="button" class="bp-toggle__btn is-active" data-unit="imperial">Imperial</button>
          <button type="button" class="bp-toggle__btn" data-unit="metric">Metric</button>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== OVERVIEW ============================== -->
  <section class="bp-overview">
    <div class="bp-overview__media">
      <img
        id="bp-gallery-main"
        src={productMain.src}
        alt="Bulk-Pak product render"
        width={productMain.width}
        height={productMain.height}
        loading="eager"
        decoding="async"
      />
    </div>

    <button type="button" class="bp-gallery__nav bp-gallery__nav--prev" aria-label="Previous image">
      <img src={arrowLeft} alt="" width="50" height="50" />
    </button>
    <button type="button" class="bp-gallery__nav bp-gallery__nav--next" aria-label="Next image">
      <img src={arrowRight} alt="" width="50" height="50" />
    </button>

    <div class="bp-gallery__thumbs" role="tablist" aria-label="Product views">
      {thumbnails.map((t, i) => (
        <button type="button" class:list={['bp-gallery__thumb', { 'is-active': i === 0 }]} data-src={t.img.src} aria-label={t.alt}>
          <img src={t.img.src} alt="" width={t.img.width} height={t.img.height} loading="lazy" decoding="async" />
        </button>
      ))}
    </div>

    <div class="bp-about">
      <p class="bp-eyebrow bp-about__eyebrow">ABOUT BULK-PAK</p>
      <p class="bp-about__desc">{aboutText}</p>
    </div>

    <div class="bp-overview__actions">
      <a href="#request-a-quote" class="bp-btn bp-btn--dark bp-overview__cta">Request a Quote</a>
      <a href="#" class="bp-btn bp-btn--outline bp-overview__download">
        Download Technical Sheet
        <img src={downloadIcon} alt="" width="14" height="15" class="bp-btn__icon" />
      </a>
    </div>
  </section>

  <!-- ============================== TECHNICAL FEATURES ============================== -->
  <section
    class="bp-features"
    id="bp-features-carousel"
    role="region"
    aria-roledescription="carousel"
    aria-label="Technical features"
    style={`--bp-autoplay-ms: ${FEATURES_AUTOPLAY_MS}ms`}
  >
    <div class="container">
      <hr class="bp-rule" />
      <header class="bp-section__head">
        <p class="bp-eyebrow bp-eyebrow--dim">FEATURES</p>
        <h2 class="bp-section__title">Technical Features</h2>
      </header>
    </div>

    <div class="bp-swiper__viewport" id="bp-features-rail" aria-live="polite">
      <div class="bp-swiper__track" data-carousel-swiper-track>
        <!-- Clone of last slide (peeks on the left of slide 0) -->
        <article class="bp-swiper__slide bp-feat" aria-hidden="true" data-carousel-clone>
          <img src={lastFeature.img.src} alt="" width={lastFeature.img.width} height={lastFeature.img.height} loading="eager" decoding="async" />
          <div class="bp-feat__gradient" aria-hidden="true"></div>
          <span class="bp-feat__tag">{lastFeature.tag}</span>
          <p class="bp-feat__desc">{lastFeature.desc}</p>
        </article>
        {
          features.map((f, si) => (
            <article
              class:list={['bp-swiper__slide', 'bp-feat', { 'is-active': si === 0 }]}
              data-carousel-swiper-slide
              data-carousel-slide-index={si}
              aria-hidden={si !== 0}
            >
              <img src={f.img.src} alt={si === 0 ? f.tag : ''} width={f.img.width} height={f.img.height} loading="eager" decoding="async" />
              <div class="bp-feat__gradient" aria-hidden="true" />
              <span class="bp-feat__tag">{f.tag}</span>
              <p class="bp-feat__desc">{f.desc}</p>
            </article>
          ))
        }
        <!-- Clone of first slide (peeks on the right of last slide) -->
        <article class="bp-swiper__slide bp-feat" aria-hidden="true" data-carousel-clone>
          <img src={firstFeature.img.src} alt="" width={firstFeature.img.width} height={firstFeature.img.height} loading="eager" decoding="async" />
          <div class="bp-feat__gradient" aria-hidden="true"></div>
          <span class="bp-feat__tag">{firstFeature.tag}</span>
          <p class="bp-feat__desc">{firstFeature.desc}</p>
        </article>
      </div>
    </div>

    <div class="container bp-swiper__controls">
      <div class="bp-swiper__controls-inner">
        <div class="bp-swiper__arrows">
          <button type="button" class="bp-swiper__arrow" aria-label="Previous slide" data-carousel-prev>
            <svg class="bp-swiper__arrow-svg" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" d="M14 7l-5 5 5 5"></path>
            </svg>
          </button>
          <button type="button" class="bp-swiper__arrow" aria-label="Next slide" data-carousel-next>
            <svg class="bp-swiper__arrow-svg" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" d="M10 7l5 5-5 5"></path>
            </svg>
          </button>
        </div>
        <div class="bp-swiper__dots-wrap">
          <div class="bp-swiper__dots" role="presentation" data-carousel-dots>
            <div class="bp-swiper__dots-track" data-carousel-dots-track>
              <div class="bp-swiper__dots-row">
                {
                  features.map((_, i) => (
                    <div class="bp-swiper__dot-slot" data-carousel-slot={i}>
                      <div class:list={['bp-swiper__dot-grow', { 'is-active': i === 0 }]}>
                        <span class="bp-swiper__dot-grow-fill" data-carousel-grow-fill />
                      </div>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== PROVEN IN THE FIELD ============================== -->
  <section class="bp-proven">
    <div class="container">
      <hr class="bp-rule" />
      <header class="bp-section__head bp-section__head--proven">
        <p class="bp-eyebrow bp-eyebrow--dim">IN USE</p>
        <h2 class="bp-section__title">Proven in the field.</h2>
      </header>
      <div class="page-grid bp-proven__grid">
        {proven.map((p) => (
          <article class="bp-proven__col">
            <div class="bp-proven__logo-slot">
              <img src={p.logo} alt={p.logoAlt} class="bp-proven__logo" style={`width:${p.logoW}px;height:${p.logoH}px`} width={p.logoW} height={p.logoH} />
            </div>
            <h3 class="bp-proven__title">{p.title}</h3>
            <p class="bp-proven__desc">{p.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================== MARKETS ============================== -->
  <section class="bp-markets">
    <div class="container">
      <hr class="bp-rule" />
      <header class="bp-section__head">
        <p class="bp-eyebrow bp-eyebrow--dim">MARKETS</p>
        <h2 class="bp-section__title">How our products are used</h2>
      </header>
      <div class="bp-markets__grid">
        {markets.map((m) => (
          <article class="bp-market">
            <div class="bp-market__media">
              <img src={m.img.src} alt={m.label} width={m.img.width} height={m.img.height} loading="lazy" decoding="async" />
              <span class="bp-market__label">{m.label}</span>
            </div>
            <p class="bp-market__desc">{m.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================== LOGISTICS FEATURES ============================== -->
  <section class="bp-logistics">
    <div class="container">
      <hr class="bp-rule" />
      <div class="page-grid bp-logistics__head">
        <header class="bp-logistics__heading">
          <p class="bp-eyebrow bp-eyebrow--dim">FEATURES</p>
          <h2 class="bp-section__title">Logistics Features</h2>
        </header>
        <p class="bp-logistics__desc">
          Lorem ipsum dolor sit amet consectetur. Viverra eget vestibulum fames aliquet venenatis suspendisse porttitor. Fringilla commodo purus id eget. Imperdiet amet eget vestibulum urna tempus arcu. Nisl cursus justo volutpat ultricies elit blandit porttitor urna. Ut sagittis enim volutpat vitae. Habitasse montes non sed fringilla turpis et.
        </p>
      </div>
      <div class="bp-logistics__media">
        <img src={truck.src} alt="Shuert branded delivery truck" width={truck.width} height={truck.height} loading="lazy" decoding="async" />
      </div>
    </div>
  </section>

  <!-- ============================== PRODUCT SYSTEM DATA ============================== -->
  <section class="bp-specs">
    <div class="container bp-specs__inner">
      <header class="bp-section__head bp-section__head--specs">
        <p class="bp-eyebrow bp-eyebrow--dim">SPECIFICATIONS</p>
        <h2 class="bp-section__title">Product System Data</h2>
      </header>

      <div class="bp-toggle bp-toggle--cream bp-specs__toggle" role="group" aria-label="Specs view">
        <button type="button" class="bp-toggle__btn is-active">Specs</button>
        <button type="button" class="bp-toggle__btn">Schematic</button>
      </div>

      <div class="page-grid bp-specs__body">
        <div class="bp-specs__intro">
          <img src={uniPakWordmark} alt="Uni-Pak" class="bp-specs__wordmark" width="191" height="57" />
          <p class="bp-specs__desc">
            Lorem ipsum dolor sit amet consectetur. Viverra eget vestibulum fames aliquet venenatis suspendisse porttitor. Fringilla commodo purus id eget. Imperdiet amet eget vestibulum urna tempus arcu. Nisl cursus justo volutpat ultricies elit blandit porttitor urna. Ut sagittis enim volutpat vitae. Habitasse montes non sed fringilla turpis et.
          </p>
        </div>

        <div class="bp-specs__scroll">
          <table class="bp-table">
            <thead>
              <tr class="bp-table__group-row">
                <th colspan="6"></th>
                {specColGroups.map((g) => (
                  <th colspan="2" class="bp-table__group">{g}</th>
                ))}
              </tr>
              <tr class="bp-table__head-row">
                {specCols.map((c) => (
                  <th>{c}</th>
                ))}
                <th>2 HIGH</th><th>3 HIGH</th>
                <th>2 HIGH</th><th>3 HIGH</th>
                <th>2 HIGH</th><th>3 HIGH</th>
              </tr>
            </thead>
            <tbody>
              {specRows.map((row) => (
                <tr>
                  {row.map((cell) => (
                    <td>{cell}</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================== OTHER SIMILAR PRODUCTS ============================== -->
  <section class="bp-related">
    <div class="container">
      <header class="bp-section__head bp-section__head--related">
        <p class="bp-eyebrow bp-eyebrow--dim">RELATED</p>
        <h2 class="bp-section__title">Other Similar Products</h2>
      </header>
      <div class="bp-related__grid">
        {related.map((r) => (
          <a class="bp-related__card" href="#">
            <div class="bp-related__media">
              <img src={r.img.src} alt={r.name} width={r.img.width} height={r.img.height} loading="lazy" decoding="async" />
            </div>
            <div class="bp-related__text">
              <h3 class="bp-related__name">{r.name}</h3>
              <p class="bp-related__size">{r.size}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="bp-related__cta">
        <a href="/products" class="bp-btn bp-btn--dark">See All Products</a>
      </div>
    </div>
  </section>

  <!-- ============================== REQUEST A QUOTE ============================== -->
  <section class="bp-quote" id="request-a-quote">
    <div class="container">
      <div class="bp-quote__grid">
        <div class="bp-quote__left">
          <p class="bp-eyebrow">REQUEST A QUOTE</p>
          <h2 class="bp-quote__title">
            Lorem ipsum dolor sit amet consectetur. Enim egestas elementum auctor cursus semper maecenas ipsum risus neque.
          </h2>

          <form class="bp-form" aria-label="Request a quote">
            <div class="bp-form__row">
              <div class="bp-field">
                <label class="bp-label" for="bp-first">FIRST NAME</label>
                <input id="bp-first" class="bp-input" type="text" placeholder="First" autocomplete="given-name" />
              </div>
              <div class="bp-field">
                <label class="bp-label" for="bp-last">LAST NAME</label>
                <input id="bp-last" class="bp-input" type="text" placeholder="Last" autocomplete="family-name" />
              </div>
            </div>

            <div class="bp-field">
              <label class="bp-label" for="bp-company">COMPANY NAME</label>
              <input id="bp-company" class="bp-input" type="text" placeholder="Company" autocomplete="organization" />
            </div>

            <div class="bp-field">
              <label class="bp-label" for="bp-email">EMAIL</label>
              <input id="bp-email" class="bp-input" type="email" placeholder="Email" autocomplete="email" />
            </div>

            <div class="bp-form__row">
              <div class="bp-field">
                <label class="bp-label" for="bp-phone">PHONE</label>
                <input id="bp-phone" class="bp-input" type="tel" placeholder="Phone" autocomplete="tel" />
              </div>
              <div class="bp-field">
                <label class="bp-label" for="bp-qty">QUANTITY</label>
                <input id="bp-qty" class="bp-input" type="number" min="0" placeholder="Quantity" />
              </div>
            </div>

            <div class="bp-field">
              <span class="bp-label">PRODUCTS OF INTEREST</span>
              <div class="bp-input bp-chips" id="bp-chips">
                <span class="bp-chip">Uni-Pak<button type="button" class="bp-chip__x" aria-label="Remove Uni-Pak">×</button></span>
                <span class="bp-chip">Uni-Directional Pallet<button type="button" class="bp-chip__x" aria-label="Remove Uni-Directional Pallet">×</button></span>
              </div>
            </div>

            <div class="bp-field">
              <label class="bp-label" for="bp-notes">ANY OTHER QUESTIONS?</label>
              <textarea id="bp-notes" class="bp-input bp-textarea" placeholder="Additional Info"></textarea>
            </div>

            <button type="submit" class="bp-btn bp-btn--dark bp-form__submit">Submit</button>
          </form>
        </div>

        <div class="bp-quote__media">
          <img src={quoteImg.src} alt="Forklift moving stacked reusable pallets in a warehouse" width={quoteImg.width} height={quoteImg.height} loading="lazy" decoding="async" />
        </div>
      </div>
    </div>
  </section>
</Mainlayout>

<script>
  // ---- Product gallery thumbnail switching ----
  const main = document.getElementById('bp-gallery-main') as HTMLImageElement | null;
  const thumbs = Array.from(document.querySelectorAll<HTMLButtonElement>('.bp-gallery__thumb'));
  let galleryIndex = 0;

  function selectThumb(i: number) {
    if (!thumbs.length || !main) return;
    galleryIndex = (i + thumbs.length) % thumbs.length;
    const src = thumbs[galleryIndex].dataset.src;
    if (src) main.src = src;
    thumbs.forEach((t, idx) => t.classList.toggle('is-active', idx === galleryIndex));
  }

  thumbs.forEach((t, i) => t.addEventListener('click', () => selectThumb(i)));
  document.querySelector('.bp-gallery__nav--prev')?.addEventListener('click', () => selectThumb(galleryIndex - 1));
  document.querySelector('.bp-gallery__nav--next')?.addEventListener('click', () => selectThumb(galleryIndex + 1));

  // ---- Unit / view pill toggles ----
  document.querySelectorAll<HTMLElement>('.bp-toggle').forEach((group) => {
    const btns = Array.from(group.querySelectorAll<HTMLButtonElement>('.bp-toggle__btn'));
    btns.forEach((btn) => {
      btn.addEventListener('click', () => {
        btns.forEach((b) => b.classList.remove('is-active'));
        btn.classList.add('is-active');
      });
    });
  });

  // ---- Chips removal ----
  document.querySelectorAll<HTMLButtonElement>('.bp-chip__x').forEach((x) => {
    x.addEventListener('click', () => x.closest('.bp-chip')?.remove());
  });

  // ---- Prevent demo form submit ----
  document.querySelector('.bp-form')?.addEventListener('submit', (e) => e.preventDefault());
</script>

<script
  define:vars={{
    bpAutoplayMs: FEATURES_AUTOPLAY_MS,
  }}
>
  /* Technical features swiper — same implementation as the careers culture carousel */
  (function () {
    const root = document.getElementById('bp-features-carousel');
    if (!root) return;

    const ANIM_NAME = 'bp-dot-progress';
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    root.style.setProperty('--bp-autoplay-ms', `${bpAutoplayMs}ms`);

    const prevBtn = root.querySelector('[data-carousel-prev]');
    const nextBtn = root.querySelector('[data-carousel-next]');
    const slotEls = root.querySelectorAll('[data-carousel-slot]');
    const realSlideEls = root.querySelectorAll('[data-carousel-swiper-slide]');
    const allSlideEls = root.querySelectorAll('.bp-swiper__slide');
    const viewport = root.querySelector('#bp-features-rail');
    const track = root.querySelector('[data-carousel-swiper-track]');

    const n = realSlideEls.length;
    let realIndex = 0;
    let domIndex = 1;
    let prevDotsIndex = -1;
    let shapeTimer = 0;
    let sliding = false;
    let ready = false;
    const SHAPE_SETTLE_MS = 480;
    var TRACK_EASE = 'transform 0.55s cubic-bezier(0.32, 0.72, 0, 1)';
    var OPACITY_EASE = 'opacity 0.45s ease';

    function getSlideMetrics() {
      var firstEl = allSlideEls[0];
      if (!firstEl || !viewport) return { slideW: 0, gap: 20, vpW: 0 };
      var vpW = viewport.getBoundingClientRect().width;
      var slideW = firstEl.getBoundingClientRect().width;
      var gap = parseFloat(getComputedStyle(track).gap) || 20;
      return { slideW: slideW, gap: gap, vpW: vpW };
    }

    function calcTranslateX(di) {
      var m = getSlideMetrics();
      var center = (m.vpW - m.slideW) / 2;
      return center - di * (m.slideW + m.gap);
    }

    function applyTransform(di, animate) {
      domIndex = di;
      var px = calcTranslateX(di);
      if (animate) {
        track.style.transition = TRACK_EASE;
      } else {
        track.style.transition = 'none';
      }
      track.style.transform = 'translateX(' + px + 'px)';

      allSlideEls.forEach(function (el, j) {
        if (animate) {
          el.style.transition = OPACITY_EASE;
        } else {
          el.style.transition = 'none';
        }
        el.classList.toggle('is-active', j === di);
      });

      if (!animate) {
        void track.offsetWidth;
      }
    }

    function setRealIndex(ri) {
      realIndex = ri;
      realSlideEls.forEach(function (el, j) {
        el.setAttribute('aria-hidden', j === realIndex ? 'false' : 'true');
      });
    }

    function refreshDots() {
      var moved = prevDotsIndex >= 0 && prevDotsIndex !== realIndex;
      window.clearTimeout(shapeTimer);

      slotEls.forEach(function (slot, i) {
        var grow = slot.querySelector('.bp-swiper__dot-grow');
        var fill = slot.querySelector('[data-carousel-grow-fill]');
        if (grow) grow.classList.toggle('is-active', i === realIndex);
        if (fill) fill.classList.remove('bp-swiper__dot-grow-fill--animating');
      });

      var activeFill = slotEls[realIndex] ? slotEls[realIndex].querySelector('[data-carousel-grow-fill]') : null;

      var startFill = function () {
        if (!activeFill || !(activeFill instanceof HTMLElement)) return;
        if (reduceMotion) return;
        void activeFill.offsetWidth;
        activeFill.classList.add('bp-swiper__dot-grow-fill--animating');
      };

      if (moved && !reduceMotion) {
        shapeTimer = window.setTimeout(startFill, SHAPE_SETTLE_MS);
      } else {
        requestAnimationFrame(startFill);
      }

      prevDotsIndex = realIndex;
    }

    function go(delta) {
      if (sliding || !ready) return;
      var nextReal = (realIndex + delta + n) % n;
      var nextDom = domIndex + delta;
      sliding = true;
      setRealIndex(nextReal);
      applyTransform(nextDom, true);
      refreshDots();
    }

    if (track) {
      track.addEventListener('transitionend', function (e) {
        if (e.target !== track) return;
        if (domIndex === 0) {
          applyTransform(n, false);
        } else if (domIndex === n + 1) {
          applyTransform(1, false);
        }
        sliding = false;
      });
    }

    prevBtn && prevBtn.addEventListener('click', function () { go(-1); });
    nextBtn && nextBtn.addEventListener('click', function () { go(1); });

    slotEls.forEach(function (slot, i) {
      var fill = slot.querySelector('[data-carousel-grow-fill]');
      if (fill) {
        fill.addEventListener('animationend', function (e) {
          if (e.animationName !== ANIM_NAME) return;
          if (i !== realIndex) return;
          go(1);
        });
      }
    });

    /* ---- Pointer / touch drag ---- */
    if (viewport && track) {
      var dragging = false;
      var startX = 0;
      var dragDelta = 0;
      var THRESHOLD = 40;

      function applyDragOffset(px) {
        var base = calcTranslateX(domIndex);
        track.style.transition = 'none';
        track.style.transform = 'translateX(' + (base + px) + 'px)';
      }

      function onDown(e) {
        if (!ready) return;
        if (e.button && e.button !== 0) return;
        dragging = true;
        startX = e.touches ? e.touches[0].clientX : e.clientX;
        dragDelta = 0;
        track.style.transition = 'none';
        viewport.style.cursor = 'grabbing';
      }

      function onMove(e) {
        if (!dragging) return;
        var clientX = e.touches ? e.touches[0].clientX : e.clientX;
        dragDelta = clientX - startX;
        applyDragOffset(dragDelta);
      }

      function onUp() {
        if (!dragging) return;
        dragging = false;
        viewport.style.cursor = '';
        if (Math.abs(dragDelta) > THRESHOLD) {
          go(dragDelta < 0 ? 1 : -1);
        } else {
          applyTransform(domIndex, true);
        }
      }

      viewport.addEventListener('pointerdown', onDown);
      viewport.addEventListener('pointermove', onMove);
      viewport.addEventListener('pointerup', onUp);
      viewport.addEventListener('pointercancel', onUp);
      viewport.addEventListener('pointerleave', onUp);

      viewport.addEventListener('touchstart', onDown, { passive: true });
      viewport.addEventListener('touchmove', onMove, { passive: true });
      viewport.addEventListener('touchend', onUp);
      viewport.addEventListener('touchcancel', onUp);

      viewport.style.touchAction = 'pan-y';
      viewport.style.cursor = 'grab';
      viewport.style.userSelect = 'none';

      viewport.addEventListener('dragstart', function (e) { e.preventDefault(); });
    }

    /* ---- Decode all images, then enable ---- */
    setRealIndex(0);
    applyTransform(1, false);

    var imgs = track ? [].slice.call(track.querySelectorAll('img')) : [];

    function decodeAll() {
      return Promise.all(imgs.map(function (img) {
        return new Promise(function (resolve) {
          if (img.complete && img.naturalWidth > 0) {
            if (img.decode) {
              img.decode().then(resolve).catch(resolve);
            } else {
              resolve();
            }
          } else {
            img.addEventListener('load', function () {
              if (img.decode) {
                img.decode().then(resolve).catch(resolve);
              } else {
                resolve();
              }
            }, { once: true });
            img.addEventListener('error', resolve, { once: true });
          }
        });
      }));
    }

    decodeAll().then(function () {
      ready = true;
      refreshDots();
    });

    var resizeTimer = 0;
    window.addEventListener('resize', function () {
      sliding = false;
      clearTimeout(resizeTimer);
      applyTransform(domIndex, false);
      resizeTimer = setTimeout(function () {
        applyTransform(domIndex, false);
      }, 150);
    });
  })();
</script>

