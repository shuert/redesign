---
import Mainlayout from '../layouts/Mainlayout.astro';
import ExploreHoverCard from '../components/ExploreHoverCard.astro';
import heroVideo from '../assets/home/Shuert Hero.mp4?url';
import showcaseGridImg from '../assets/home/showcase/442c4945dd362268b980a5ca97e20f26e7ebd454.png';
import exploreCapabilitiesImg from '../assets/home/Rectangle 30.png';
import exploreAboutImg from '../assets/home/Rectangle 29.png';
import iconAutomotive from '../assets/markets/7c61e96fd523fbfee58ef2dc967fb250ae0ac962.svg?url';
import iconAgriculture from '../assets/markets/e437b82618ada1bd3baea1071885d346ec78d1e1.svg?url';
import iconAutomatedSystems from '../assets/home/7850fb2d2eeabb768ee1c47c0e2307c7bbddb2da.svg?url';
import iconConstruction from '../assets/markets/6fcc977319170cad548333e2c75f6119f095e1fe.svg?url';
import iconEcommerce from '../assets/markets/e599fe2c8709a6a434485eab6b63c610d1fe9613.svg?url';
import iconFmcg from '../assets/markets/499b89d1df290e0ae8c1f320fb7b23f10a622137.svg?url';
import reachOutImg from '../assets/home/60c26e97b304b786a121896cb8a9ba9c10e748e0.png';

import swpfUniCase from '../assets/home/showcase/4b170503a9b59eff640b0edc203460e636770be1.png';
import swpfYarnPak from '../assets/home/showcase/8814d643574ff518056f6ce26f4edefd5d46a80e.png';
import swpfBatteryRak from '../assets/home/showcase/108ec376df65f3cc0ee4220601ba12405b08659c.png';
import swpfModulePak from '../assets/home/showcase/03a91da25f7f86086463e14458bcd279277f5709.png';
import swpfUniPakIi from '../assets/home/showcase/c7cebf8f9dab13617207e179bf6b69ac9347fefe.png';
import swpfUniPak from '../assets/home/showcase/974cb1b76ab2b91a796aa3a198c5be826cc8c78e.png';
import swpfSnapPak from '../assets/home/showcase/f5f5968a699aeb53db959a87cccd4ce29090a0e1.png';
import swpfBulkPak from '../assets/home/showcase/6661c68d4e4964b1fbfe9142352dda22f14600c9.png';
import swpfProPak from '../assets/home/showcase/9a9f3efdb18c2bfd8a9c201d7875e9d99d2add75.png';
import swpfRemanPak from '../assets/home/showcase/a263c45ea647f3f8932e045b690d6e28e2a6439c.png';
import swpfBatteryShell from '../assets/home/showcase/d910fec071e11b9db902c06d71b2330200ee5cfc.png';
import swpfUniRak from '../assets/home/showcase/7263cce3121718fdd3b45b63d5778ae2f16a836e.png';
import swpfAxlePak from '../assets/home/showcase/7869141aff8f1052144c41e39e4b6094958a27c6.png';
import swpfTerraRoad from '../assets/home/showcase/712acef20e697dbe2c9efed8c200a1858bad65b6.png';
import swpfUniDirectional from '../assets/home/showcase/df2d10cd900107fb5cd9da3677993ef0dc1bd546.png';
import swpfUniPallet from '../assets/home/showcase/05d946f9598c18c84bbd6a0600beea44850414f7.png';
import swpfPerimeterBase from '../assets/home/showcase/7086a744aeb4ac6e8b63c7a8367846740eb17c79.png';

const ART_W = 1727;
const ART_H = 1248;
const SWPF_SIZE = 668.432;

const marketDesc =
  'Lorem ipsum dolor sit amet consectetur. Eu condimentum at enim duis lectus pulvinar.';

const markets = [
  { name: 'Automotive', icon: iconAutomotive, iw: 36, ih: 27, desc: marketDesc },
  { name: 'Agriculture', icon: iconAgriculture, iw: 28, ih: 35, desc: marketDesc },
  { name: 'Automated Systems', icon: iconAutomatedSystems, iw: 35, ih: 35, desc: marketDesc },
  { name: 'Construction', icon: iconConstruction, iw: 34, ih: 34, desc: marketDesc },
  { name: 'E-Commerce', icon: iconEcommerce, iw: 34, ih: 35, desc: marketDesc },
  { name: 'Fast Moving Consumer Goods', icon: iconFmcg, iw: 35, ih: 35, desc: marketDesc },
  { name: 'Government', icon: iconConstruction, iw: 34, ih: 34, desc: marketDesc },
  { name: 'Grocery', icon: iconEcommerce, iw: 34, ih: 35, desc: marketDesc },
  { name: 'Military', icon: iconFmcg, iw: 35, ih: 35, desc: marketDesc },
  { name: 'Pharmaceutical/Medical', icon: iconConstruction, iw: 34, ih: 34, desc: marketDesc },
  { name: 'Textiles', icon: iconEcommerce, iw: 34, ih: 35, desc: marketDesc },
];

/** Figma Frame 155 (2003:8154) product positions on 1727×1248 artboard */
const showcaseProducts = [
  { id: 'uni-case', name: 'uni-case', href: '/products/uni-case', left: 562.72, top: -26.9, flip: false, image: swpfUniCase },
  { id: 'yarn-pak', name: 'yarn-pak', href: '/products/yarn-pak', left: 789.52, top: 110.41, flip: false, image: swpfYarnPak },
  { id: 'battery-rak', name: 'battery-rak', href: '/products/battery-pak', left: 1058.57, top: 254.47, flip: true, image: swpfBatteryRak },
  { id: 'module-pak', name: 'module-pak', href: '#', left: 259.04, top: 49.38, flip: false, image: swpfModulePak },
  { id: 'uni-pak-ii', name: 'uni-pak II', href: '/products/unipak', left: 433.33, top: 147.38, flip: false, image: swpfUniPakIi },
  { id: 'uni-pak', name: 'uni-pak', href: '/products/unipak', left: 608.49, top: 253.3, flip: false, image: swpfUniPak },
  { id: 'snap-pak', name: 'snap-pak', href: '#', left: 773.38, top: 357.75, flip: false, image: swpfSnapPak },
  { id: 'bulk-pak', name: 'bulk-pak', href: '/products/bulk-pak', left: 947.66, top: 455.75, flip: false, image: swpfBulkPak },
  { id: 'pro-pak', name: 'pro-pak', href: '/products/pro-pak', left: 48.17, top: 134.12, flip: false, image: swpfProPak },
  { id: 'reman-pak', name: 'reman-pak', href: '/products/reman-pak', left: 183.43, top: 212.16, flip: false, image: swpfRemanPak },
  { id: 'battery-shell', name: 'battery-shell', href: '#', left: 327.78, top: 307.23, flip: false, image: swpfBatteryShell },
  { id: 'uni-rak', name: 'uni-rak', href: '/products/uni-rak', left: 548.23, top: 432.64, flip: true, image: swpfUniRak },
  { id: 'axle-pak', name: 'axle-pak', href: '#', left: 785.37, top: 559.5, flip: false, image: swpfAxlePak },
  { id: 'terra-road', name: 'terra-road', href: '#', left: 1.33, top: 342.96, flip: true, image: swpfTerraRoad },
  { id: 'uni-directional', name: 'uni-directional', href: '/products/uni-directional-pallet', left: 183.82, top: 463.97, flip: false, image: swpfUniDirectional },
  { id: 'uni-pallet', name: 'uni-pallet', href: '/products/uni-pallet', left: 301.18, top: 532.03, flip: false, image: swpfUniPallet },
  { id: 'perimeter-base', name: 'perimeter-base', href: '#', left: 436.64, top: 607.25, flip: false, image: swpfPerimeterBase },
].map((p) => ({
  ...p,
  style: {
    left: `${(p.left / ART_W) * 100}%`,
    top: `${(p.top / ART_H) * 100}%`,
    width: `${(SWPF_SIZE / ART_W) * 100}%`,
    height: `${(SWPF_SIZE / ART_H) * 100}%`,
  },
}));

/** Back-to-front stagger along the isometric layout (top → bottom, then left → right) */
const showcaseRevealOrder = Object.fromEntries(
  [...showcaseProducts]
    .sort((a, b) => a.top - b.top || a.left - b.left)
    .map((p, i) => [p.id, i]),
);
---

<Mainlayout title="Home">
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <video
        class="hero__video"
        src={heroVideo}
        muted
        playsinline
        loop
        autoplay
        preload="auto"
      ></video>
      <div class="hero__gradient"></div>
    </div>

    <div class="hero__content container">
      <div class="page-grid hero__grid">
        <div class="hero__text col-full">
          <h1 class="detail-xl text-white">leaders in reusable<br />transport packaging</h1>
          <p class="p-lg text-white hero__subtitle">
            Providing Innovative Supply Chain<br />Solutions Since 1971
          </p>
          <a href="/products" class="button button-glass">See All Products</a>
        </div>
      </div>

      <div class="hero__scroll">
        <span class="label text-white">Learn More</span>
        <button class="hero__scroll-btn" type="button" aria-label="Scroll down">
          <svg xmlns="http://www.w3.org/2000/svg" width="50" height="50" viewBox="0 0 50 50" fill="none">
            <circle cx="25" cy="25" r="25" transform="rotate(-90 25 25)" fill="#F7F5F2"/>
            <path d="M29.6063 27.7738L24.8032 32.5769L20.0001 27.7738" stroke="black" stroke-linecap="round"/>
            <path d="M24.8032 32.5772L24.8032 17.4229" stroke="black" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>
  </section>

  <section class="statement">
    <div class="container">
      <div class="page-grid">
        <h2 class="statement__heading text-white reveal">
          Products built to handle, transport, and protect goods across the supply chain, again and again.
        </h2>
      </div>
    </div>
  </section>

  <section
    class="showcase"
    id="product-showcase"
    aria-label="Product family preview"
    data-state="idle"
  >
    <div class="showcase__grid-bg" aria-hidden="true">
      <img
        src={showcaseGridImg.src}
        alt=""
        class="showcase__grid-img"
        width={showcaseGridImg.width}
        height={showcaseGridImg.height}
        loading="lazy"
        decoding="async"
      />
      <div class="showcase__vignette"></div>
    </div>

    <div class="showcase__viewport">
      <div class="showcase__stage">
        {showcaseProducts.map((product, index) => (
          <button
            type="button"
            class:list={['showcase__product', product.flip && 'showcase__product--flip']}
            style={`left:${product.style.left};top:${product.style.top};width:${product.style.width};height:${product.style.height};z-index:${index + 1};--reveal-i:${showcaseRevealOrder[product.id] ?? index}`}
            data-product-id={product.id}
            data-name={`${product.name}®`}
            data-href={product.href}
            aria-label={`Explore ${product.name}`}
          >
            <img
              src={product.image.src}
              alt=""
              class="showcase__product-img"
              width={product.image.width}
              height={product.image.height}
              loading="lazy"
              decoding="async"
              draggable="false"
              crossorigin="anonymous"
            />
          </button>
        ))}
      </div>
    </div>

    <p class="showcase__side-label" data-side="left" hidden aria-hidden="true"></p>

    <p class="showcase__hint label">Hover to Explore</p>
  </section>

  <section class="explore-pair">
    <div class="container">
      <div class="explore-pair__grid">
        <ExploreHoverCard
          href="/capabilities"
          image={exploreCapabilitiesImg}
          imageAlt="Forklift and CNC machine in Shuert manufacturing"
          eyebrow="Capabilities"
          eyebrowVariant="plain"
          title="End-to-end control through in-house capability."
          cta="Explore Our Capabilities"
        />
        <ExploreHoverCard
          href="/about/whyshuert"
          image={exploreAboutImg}
          imageAlt="Team inspecting a wooden mold in the workshop"
          eyebrow="The Shuert Advantage"
          eyebrowVariant="pill"
          title="From the start with material selection, we've never compromised the product."
          cta="Learn About Shuert"
        />
      </div>
    </div>
  </section>

  <section class="markets-grid" aria-labelledby="markets-heading">
    <div class="container markets-grid__inner">
      <header class="markets-grid__header">
        <p class="label markets-grid__eyebrow">Markets we work in</p>
        <h2 id="markets-heading" class="markets-grid__title text-white reveal">
          Products to serve every market
        </h2>
      </header>

      <div class="markets-grid__cells">
        {markets.map((market) => (
          <article class="markets-cell">
            <div class="markets-cell__top">
              <img
                class="markets-cell__icon"
                src={market.icon}
                alt=""
                width={market.iw}
                height={market.ih}
              />
              <h3 class="markets-cell__name">{market.name}</h3>
            </div>
            <p class="markets-cell__desc">{market.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="reach-out" aria-labelledby="reach-out-heading">
    <div class="container reach-out__inner">
      <div class="reach-out__grid">
        <div class="reach-out__content">
          <p class="label reach-out__eyebrow" style="color: rgba(255, 255, 255, 0.35);">Reach out</p>
          <h2 id="reach-out-heading" class="reach-out__title text-white reveal">
            Stay in the loop on all<br />
            things Shuert, from product updates to exhibitions we’re attending.
          </h2>
          <form class="reach-out__form" aria-label="Email updates">
            <div class="reach-out__field">
              <input
                type="email"
                id="reach-out-email"
                name="email"
                class="reach-out__input"
                placeholder="Email Address"
                autocomplete="email"
                inputmode="email"
                aria-label="Email address"
              />
              <button type="submit" class="reach-out__submit">Submit</button>
            </div>
          </form>
        </div>
        <div class="reach-out__media">
          <img
            src={reachOutImg.src}
            alt="Forklift and stacked reusable pallets in a Shuert warehouse"
            class="reach-out__img"
            width={reachOutImg.width}
            height={reachOutImg.height}
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>
</Mainlayout>

<script>
  const hero = document.querySelector('.hero');
  const heroBg = document.querySelector('.hero__bg');
  const heroContent = document.querySelector('.hero__content');
  const heroVideoEl = document.querySelector('.hero__video');

  if (heroVideoEl instanceof HTMLVideoElement) {
    const startAtRandom = () => {
      const duration = heroVideoEl.duration;
      if (!Number.isFinite(duration) || duration <= 0) return;
      /* Avoid landing exactly on the end frame before loop */
      heroVideoEl.currentTime = Math.random() * Math.max(duration - 0.25, 0);
      heroVideoEl.play().catch(() => {});
    };

    if (heroVideoEl.readyState >= 1) startAtRandom();
    else heroVideoEl.addEventListener('loadedmetadata', startAtRandom, { once: true });
  }

  if (hero && heroBg && heroContent) {
    let currentBgY = 0;
    let targetBgY = 0;
    const ease = 0.06;

    const lerp = (a, b, t) => a + (b - a) * t;

    const onScroll = () => {
      const scrollY = window.scrollY;
      const heroH = hero.offsetHeight;
      const progress = Math.min(scrollY / heroH, 1);

      targetBgY = scrollY * 0.15;
      heroContent.style.opacity = String(1 - progress * 1.5);
      heroContent.style.transform = `translateY(${scrollY * -0.3}px)`;
    };

    const animate = () => {
      currentBgY = lerp(currentBgY, targetBgY, ease);
      heroBg.style.transform = `translateY(${currentBgY}px)`;
      requestAnimationFrame(animate);
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    animate();
  }

  const reveals = document.querySelectorAll('.reveal');
  if (reveals.length) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('reveal--visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    reveals.forEach((el) => observer.observe(el));
  }

  const showcaseReveal = document.querySelector('#product-showcase');
  if (showcaseReveal instanceof HTMLElement) {
    const revealProducts = Array.from(
      showcaseReveal.querySelectorAll('.showcase__product'),
    );
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const revealShowcase = () => {
      showcaseReveal.classList.add('is-revealed');
      if (prefersReducedMotion) {
        revealProducts.forEach((el) => el.classList.add('is-focused'));
        return;
      }
      revealProducts.forEach((el) => {
        if (!(el instanceof HTMLElement)) return;
        const i = Number(el.style.getPropertyValue('--reveal-i')) || 0;
        window.setTimeout(() => el.classList.add('is-focused'), i * 110);
      });
    };

    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          revealShowcase();
          revealObserver.unobserve(entry.target);
        });
      },
      { threshold: 0.2, rootMargin: '0px 0px -8% 0px' },
    );
    revealObserver.observe(showcaseReveal);
  }

  const reachOutForm = document.querySelector('.reach-out__form');
  reachOutForm?.addEventListener('submit', (e) => {
    e.preventDefault();
  });

  /* ── Product showcase (Figma 1581:1556 hover → navigate on click) ── */
  const showcase = document.querySelector('#product-showcase');
  if (showcase instanceof HTMLElement) {
    const stage = showcase.querySelector('.showcase__stage');
    const viewport = showcase.querySelector('.showcase__viewport');
    const sideLabel = showcase.querySelector('.showcase__side-label');
    const products = Array.from(showcase.querySelectorAll('.showcase__product'));
    /** @type {HTMLElement | null} */
    let hovered = null;
    /** @type {WeakMap<HTMLImageElement, { data: Uint8ClampedArray, w: number, h: number }>} */
    const alphaCache = new WeakMap();
    let moveRaf = 0;
    let pendingX = 0;
    let pendingY = 0;

    const setState = (state) => {
      showcase.dataset.state = state;
      if (sideLabel instanceof HTMLElement) {
        const showLabel = state === 'hover';
        sideLabel.hidden = !showLabel;
        sideLabel.setAttribute('aria-hidden', showLabel ? 'false' : 'true');
      }
    };

    const placeSideLabel = (product) => {
      if (!(sideLabel instanceof HTMLElement) || !(product instanceof HTMLElement)) return;
      sideLabel.textContent = product.getAttribute('data-name') || '';

      const stageEl = stage instanceof HTMLElement ? stage : showcase;
      const stageRect = stageEl.getBoundingClientRect();
      const prodRect = product.getBoundingClientRect();
      const centerX = prodRect.left + prodRect.width / 2 - stageRect.left;
      sideLabel.dataset.side = centerX >= stageRect.width / 2 ? 'left' : 'right';
    };

    const clearHover = () => {
      hovered = null;
      products.forEach((el) => el.classList.remove('is-hovered'));
      viewport?.classList.remove('is-over-product');
      setState('idle');
    };

    const setHover = (product) => {
      if (hovered === product) return;
      hovered = product;
      products.forEach((el) => {
        el.classList.toggle('is-hovered', el === product);
      });
      viewport?.classList.add('is-over-product');
      placeSideLabel(product);
      setState('hover');
    };

    const getAlphaData = (img) => {
      if (!(img instanceof HTMLImageElement) || !img.complete || img.naturalWidth === 0) return null;
      const cached = alphaCache.get(img);
      if (cached) return cached;
      try {
        const canvas = document.createElement('canvas');
        canvas.width = img.naturalWidth;
        canvas.height = img.naturalHeight;
        const ctx = canvas.getContext('2d', { willReadFrequently: true });
        if (!ctx) return null;
        ctx.drawImage(img, 0, 0);
        const { data } = ctx.getImageData(0, 0, canvas.width, canvas.height);
        const entry = { data, w: canvas.width, h: canvas.height };
        alphaCache.set(img, entry);
        return entry;
      } catch {
        return null;
      }
    };

    const sampleAlpha = (product, clientX, clientY) => {
      const img = product.querySelector('.showcase__product-img');
      if (!(img instanceof HTMLImageElement)) return 0;
      const rect = product.getBoundingClientRect();
      if (
        clientX < rect.left ||
        clientX > rect.right ||
        clientY < rect.top ||
        clientY > rect.bottom
      ) {
        return 0;
      }

      let u = (clientX - rect.left) / rect.width;
      let v = (clientY - rect.top) / rect.height;
      /* Flipped assets use scaleY(-1) rotate(180deg) ≡ horizontal mirror */
      if (product.classList.contains('showcase__product--flip')) {
        u = 1 - u;
      }

      const alpha = getAlphaData(img);
      if (!alpha) {
        return u > 0.25 && u < 0.75 && v > 0.25 && v < 0.75 ? 255 : 0;
      }

      const x = Math.min(alpha.w - 1, Math.max(0, Math.floor(u * alpha.w)));
      const y = Math.min(alpha.h - 1, Math.max(0, Math.floor(v * alpha.h)));
      return alpha.data[(y * alpha.w + x) * 4 + 3];
    };

    const hitTest = (clientX, clientY) => {
      /* Topmost first — later DOM nodes paint above */
      for (let i = products.length - 1; i >= 0; i -= 1) {
        const product = products[i];
        if (!(product instanceof HTMLElement)) continue;
        if (sampleAlpha(product, clientX, clientY) > 24) return product;
      }
      return null;
    };

    const onPointerMove = (clientX, clientY) => {
      const hit = hitTest(clientX, clientY);
      if (hit) setHover(hit);
      else if (hovered) clearHover();
    };

    viewport?.addEventListener(
      'pointermove',
      (e) => {
        pendingX = e.clientX;
        pendingY = e.clientY;
        if (moveRaf) return;
        moveRaf = requestAnimationFrame(() => {
          moveRaf = 0;
          onPointerMove(pendingX, pendingY);
        });
      },
      { passive: true },
    );

    viewport?.addEventListener('pointerleave', () => {
      if (moveRaf) {
        cancelAnimationFrame(moveRaf);
        moveRaf = 0;
      }
      clearHover();
    });

    viewport?.addEventListener('click', (e) => {
      const hit = hitTest(e.clientX, e.clientY) || hovered;
      if (!hit) return;
      e.preventDefault();
      const href = hit.getAttribute('data-href') || '/products';
      window.location.href = href === '#' ? '/products' : href;
    });

    products.forEach((product) => {
      product.addEventListener('focus', () => setHover(product));
      product.addEventListener('blur', () => {
        if (hovered === product) clearHover();
      });
      product.addEventListener('keydown', (e) => {
        if (e.key !== 'Enter' && e.key !== ' ') return;
        e.preventDefault();
        const href = product.getAttribute('data-href') || '/products';
        window.location.href = href === '#' ? '/products' : href;
      });
    });

    /* Warm alpha caches once images decode */
    products.forEach((product) => {
      const img = product.querySelector('.showcase__product-img');
      if (!(img instanceof HTMLImageElement)) return;
      if (img.complete) getAlphaData(img);
      else img.addEventListener('load', () => getAlphaData(img), { once: true });
    });
  }
</script>

<style>
  .hero {
    position: sticky;
    top: 0;
    z-index: 1;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
    background: var(--c-black);
  }

  /* ── Background video layer ── */
  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    will-change: transform;
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center center;
  }

  .hero__gradient {
    position: absolute;
    inset: 0;
