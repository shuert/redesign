---
export type AboutSection = 'who-we-are' | 'why-shuert' | 'careers';

interface Props {
  current: AboutSection;
}

const { current } = Astro.props;

const links: { href: string; id: AboutSection; label: string }[] = [
  { href: '/about', id: 'who-we-are', label: 'Who We Are' },
  { href: '/about/whyshuert', id: 'why-shuert', label: 'Why Shuert' },
  { href: '/about/careers', id: 'careers', label: 'Careers' },
];
---

<div class="about-subnav" id="about-subnav" aria-label="About section">
  <nav class="about-subnav__inner" id="about-subnav-inner">
    <span class="about-subnav__pill" id="about-subnav-pill" aria-hidden="true"></span>
    {
      links.map((link) => (
        <a
          href={link.href}
          class="about-subnav__link"
          aria-current={link.id === current ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))
    }
  </nav>
</div>

<script is:inline>
  (function () {
    const subnav = document.getElementById('about-subnav');
    const inner = document.getElementById('about-subnav-inner');
    const pill = document.getElementById('about-subnav-pill');
    if (!subnav || !inner || !pill) return;

    const linkEls = inner.querySelectorAll('.about-subnav__link');
    let activeLink = null;

    function pathMatchHref(pathNorm, hrefNorm) {
      if (hrefNorm === '/about') return pathNorm === '/about';
      return pathNorm === hrefNorm;
    }

    function setActiveFromLocation() {
      const path = (window.location.pathname.replace(/\/$/, '') || '/').toLowerCase();
      activeLink = null;
      linkEls.forEach((link) => {
        const hrefRaw = link.getAttribute('href') || '';
        const hrefNorm = (hrefRaw.replace(/\/$/, '') || '/').toLowerCase();
        if (pathMatchHref(path, hrefNorm)) {
          activeLink = link;
        }
      });
    }

    function movePill(el) {
      if (!(el instanceof HTMLElement)) return;
      linkEls.forEach((a) => a.classList.remove('about-subnav__link--on-pill'));
      el.classList.add('about-subnav__link--on-pill');
      const linkRect = el.getBoundingClientRect();
      const innerRect = inner.getBoundingClientRect();
      pill.style.left = linkRect.left - innerRect.left + 'px';
      pill.style.top = linkRect.top - innerRect.top + 'px';
      pill.style.width = linkRect.width + 'px';
      pill.style.height = linkRect.height + 'px';
      pill.style.opacity = '1';
    }

    function hidePill() {
      linkEls.forEach((a) => a.classList.remove('about-subnav__link--on-pill'));
      pill.style.opacity = '0';
    }

    setActiveFromLocation();
    if (activeLink) movePill(activeLink);

    linkEls.forEach((link) => {
      link.addEventListener('mouseenter', () => movePill(link));
    });

    inner.addEventListener('mouseleave', () => {
      if (activeLink) movePill(activeLink);
      else hidePill();
    });

    window.addEventListener('resize', () => {
      if (activeLink) movePill(activeLink);
    });

    document.addEventListener('visibilitychange', () => {
      if (!document.hidden && activeLink) movePill(activeLink);
    });

    const threshold = 32;
    function onScroll() {
      if (window.scrollY > threshold) {
        subnav.classList.add('about-subnav--visible');
        requestAnimationFrame(() => {
          if (activeLink) movePill(activeLink);
        });
      } else {
        subnav.classList.remove('about-subnav--visible');
      }
    }
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  })();
</script>

<style>
  .about-subnav {
    position: fixed;
    z-index: 90;
    left: var(--grid-margin);
    right: var(--grid-margin);
    bottom: 10px;
    display: flex;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.35s ease,
      transform 0.35s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .about-subnav {
      transition: opacity 0.2s ease;
      transform: none;
    }
  }

  .about-subnav--visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .about-subnav--visible {
      transform: none;
    }
  }

  .about-subnav__inner {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: clamp(1rem, 2vw, 35px);
    min-height: 49px;
    padding: 7px 9px;
    box-sizing: border-box;
    border-radius: 24.5px;
    background: rgb(0 0 0 / 0.9);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .about-subnav__pill {
    position: absolute;
    background: var(--c-white);
    border-radius: 20px;
    padding: 6px 18px;
    pointer-events: none;
    opacity: 0;
    z-index: 0;
    box-sizing: border-box;
    transition:
      left 0.3s ease,
      top 0.3s ease,
      width 0.3s ease,
      height 0.3s ease,
      opacity 0.2s ease;
  }

  .about-subnav__link {
    position: relative;
    z-index: 1;
    padding: 6px 18px;
    border-radius: 20px;
    text-decoration: none;
    font: var(--w-medium) 16px / 1 var(--ff-r);
    color: var(--c-white);
    white-space: nowrap;
  }

  .about-subnav__link--on-pill {
    color: var(--c-black);
  }

  .about-subnav__link:hover {
    text-decoration: none;
  }

  .about-subnav__link:focus-visible {
    outline: 2px solid var(--c-white);
    outline-offset: 3px;
  }

  .about-subnav__link--on-pill:focus-visible {
    outline-color: var(--c-black);
  }
</style>
