---
import logoIcon from '../assets/footer/4e9e84abb816721d20f51c619acee6ec8c381919.svg';
import logoText from '../assets/footer/1aa99970454bb619d8bb1c1ef4ecc22a05bd6df4.svg';
---

<footer class="footer">
  <div class="footer__logo container">
    <div class="footer__logo-inner">
      <img src={logoIcon.src} alt="" class="footer__logo-icon" width="371" height="309" />
      <img src={logoText.src} alt="Shuert" class="footer__logo-text" width="1158" height="311" />
    </div>
  </div>

  <div class="footer__content container">
    <div class="footer__products">
      <p class="label footer__heading">Products</p>
      <div class="footer__link-cols">
        <ul class="footer__link-list">
          <li><a href="/products/">Uni-Pak</a></li>
          <li><a href="/products/">Uni-Pallet</a></li>
          <li><a href="/products/">Uni-Directional Pallet</a></li>
          <li><a href="/products/">Uni-Case</a></li>
          <li><a href="/products/">Uni-Rak</a></li>
        </ul>
        <ul class="footer__link-list">
          <li><a href="/products/">Yarn-Pak</a></li>
          <li><a href="/products/">Pro-Pak</a></li>
          <li><a href="/products/">Reman-Pak</a></li>
          <li><a href="/products/">Battery-Pak</a></li>
          <li><a href="/products/">Custom</a></li>
        </ul>
      </div>
    </div>

    <div class="footer__divider" aria-hidden="true"></div>

    <div class="footer__pages">
      <p class="label footer__heading">Pages</p>
      <div class="footer__pages-inner">
        <div class="footer__link-cols">
          <ul class="footer__link-list">
            <li><a href="/markets/">Markets</a></li>
            <li><a href="/capabilities/">Capabilities</a></li>
            <li><a href="/custom-solutions/">Custom Solutions</a></li>
            <li><a href="/sustainability/">Sustainability</a></li>
            <li><a href="/about/">About</a></li>
          </ul>
          <ul class="footer__link-list">
            <li><a href="/about/">Careers</a></li>
            <li><a href="/about/">Who We Are</a></li>
            <li><a href="/about/">Why Shuert?</a></li>
            <li><a href="/contact/">Contact</a></li>
            <li><a href="/contact/">Request a Quote</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer__newsletter">
      <p class="label footer__heading">Stay in the Know</p>
      <div class="footer__newsletter-body">
        <form class="footer__form">
          <div class="footer__form-inner">
            <input type="email" placeholder="Email Address" class="footer__input" required aria-label="Email Address" />
            <button type="submit" class="footer__submit">Submit</button>
          </div>
        </form>
        <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="footer__social">LinkedIn</a>
      </div>
    </div>
  </div>

  <div class="footer__bottom container">
    <p class="footer__copyright">&copy; SHUERT TECHNOLOGIES 2025 ALL RIGHTS RESERVED</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--c-black);
    color: var(--c-white);
    overflow: hidden;
  }

  /* ---- Logo area ---- */

  .footer__logo {
    padding-top: clamp(3rem, 6.5vw, 4.3125rem);
    padding-bottom: clamp(4rem, 22vw, 24rem);
  }

  .footer__logo-inner {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 4.3vw, 4.3125rem);
  }

  .footer__logo-icon {
    width: 23.2%;
    height: auto;
    flex-shrink: 0;
  }

  .footer__logo-text {
    flex: 1;
    min-width: 0;
    height: auto;
  }

  /* ---- Links content ---- */

  .footer__content {
    position: relative;
    display: grid;
    grid-template-columns: repeat(var(--grid-cols), minmax(0, 1fr));
    grid-template-rows: auto 1fr;
    gap: 0 var(--grid-gutter);
  }

  .footer__heading {
    margin: 0 0 2.5rem;
    color: var(--c-white);
  }

  .footer__products {
    grid-column: 1 / 5;
    grid-row: 1 / -1;
    display: grid;
    grid-template-rows: subgrid;
  }

  .footer__divider {
    position: absolute;
    left: 30%;
    top: 0;
    bottom: 0;
    width: 1px;
    background: #333;
  }

  .footer__pages {
    grid-column: 5 / 9;
    grid-row: 1 / -1;
    display: grid;
    grid-template-rows: subgrid;
  }

  .footer__pages-inner {
    display: flex;
    gap: clamp(2rem, 5vw, 6rem);
  }

  .footer__newsletter {
    grid-column: 9 / -1;
    grid-row: 1 / -1;
    display: grid;
    grid-template-rows: subgrid;
  }

  .footer__newsletter-body {
    display: flex;
    flex-direction: column;
  }

  .footer__form {
    margin: 0;
  }

  /* ---- Link columns ---- */

  .footer__link-cols {
    display: flex;
    gap: clamp(2rem, 5vw, 5.625rem);
  }

  .footer__link-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer__link-list li {
    line-height: 30px;
  }

  .footer__link-list a {
    font: var(--w-light) 1rem / 30px var(--ff-r);
    color: var(--c-white);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .footer__link-list a:hover {
    opacity: 0.7;
  }

  /* ---- Social link ---- */

  .footer__social {
    display: inline-block;
    margin-top: auto;
    font: var(--w-light) 1rem / 30px var(--ff-r);
    color: var(--c-white);
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  .footer__social:hover {
    opacity: 0.7;
  }

  /* ---- Newsletter form ---- */

  .footer__form-inner {
    display: flex;
    align-items: center;
    background: #212120;
    border-radius: 0.875rem;
    padding: 0.375rem 0.375rem 0.375rem 1.5rem;
    width: 100%;
  }

  .footer__input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    outline: none;
    font: var(--w-medium) 1rem / normal var(--ff-r);
    color: var(--c-white);
    padding: 0.75rem 0;
  }

  .footer__input::placeholder {
    color: var(--c-white);
    opacity: 1;
  }

  .footer__submit {
    flex-shrink: 0;
    background: var(--c-white);
    color: var(--c-black);
    border: none;
    border-radius: 0.5rem;
    padding: 0.9375rem 1.125rem;
    font: var(--w-medium) 1rem / normal var(--ff-r);
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .footer__submit:hover {
    opacity: 0.9;
  }

  /* ---- Copyright ---- */

  .footer__bottom {
    padding-top: clamp(1.5rem, 3vw, 2.25rem);
    padding-bottom: 1.75rem;
    display: flex;
    justify-content: flex-end;
  }

  .footer__copyright {
    margin: 0;
    font: var(--w-bold) 0.625rem / 1 var(--ff-s);
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: var(--c-sec-1);
  }

  /* ---- Tablet (<=1024px) ---- */

  @media (max-width: 64rem) {
    .footer__logo {
      padding-bottom: clamp(3rem, 10vw, 10rem);
    }

    .footer__content {
      grid-template-rows: auto;
    }

    .footer__products {
      grid-column: 1 / 5;
      grid-row: auto;
      display: block;
    }

    .footer__divider {
      display: none;
    }

    .footer__pages {
      grid-column: 5 / -1;
      grid-row: auto;
      display: block;
    }

    .footer__newsletter {
      grid-column: 1 / -1;
      grid-row: auto;
      display: block;
      margin-top: 2rem;
    }
  }

  /* ---- Mobile (<=768px) ---- */

  @media (max-width: 48rem) {
    .footer__content {
      gap: 2.5rem var(--grid-gutter);
    }

    .footer__products,
    .footer__pages {
      grid-column: 1 / -1;
    }

    .footer__newsletter {
      margin-top: 0;
    }

    .footer__link-cols {
      gap: 2.5rem;
    }

    .footer__bottom {
      justify-content: center;
    }
  }
</style>
