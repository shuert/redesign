---
interface Props {
  name: string;
  options: readonly string[];
  placeholder?: string;
  id?: string;
}

const {
  name,
  options,
  placeholder = 'Type or select…',
  id = name,
} = Astro.props;

const listId = `${id}-listbox`;
---

<div
  class="ms"
  data-multi-select
  data-name={name}
  data-options={JSON.stringify(options)}
>
  <input type="hidden" name={name} value="" data-ms-value />
  <div class="ms__control" data-ms-control>
    <div class="ms__tags" data-ms-tags></div>
    <input
      id={id}
      type="text"
      class="ms__input"
      data-ms-input
      placeholder={placeholder}
      autocomplete="off"
      role="combobox"
      aria-autocomplete="list"
      aria-expanded="false"
      aria-controls={listId}
      aria-haspopup="listbox"
    />
    <button
      type="button"
      class="ms__caret"
      data-ms-caret
      aria-label="Toggle options"
      tabindex="-1"
    >
      <svg width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
        <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
  <ul class="ms__list" id={listId} role="listbox" data-ms-list hidden></ul>
</div>

<style is:global>
  .ms {
    position: relative;
    width: 100%;
  }

  .ms__control {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    width: 100%;
    min-height: 44px;
    padding: 7px 36px 7px 7px;
    background: var(--c-black);
    border: none;
    border-radius: 8px;
    box-sizing: border-box;
    cursor: text;
  }

  .ms__control:focus-within {
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.2);
  }

  .ms__tags {
    display: contents;
  }

  .ms__tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 30px;
    padding: 0 12px;
    background: var(--c-white);
    border-radius: 50px;
    font: var(--w-semibold) 16px / 1 var(--ff-s);
    color: var(--c-black);
    white-space: nowrap;
  }

  .ms__tag-x {
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    background: none;
    border: none;
    padding: 0;
    color: inherit;
  }

  .ms__input {
    flex: 1 1 120px;
    min-width: 120px;
    height: 30px;
    margin: 0;
    padding: 0 4px;
    background: transparent;
    border: none;
    outline: none;
    color: var(--c-white);
    font: 400 16px / 22px var(--ff-r);
  }

  .ms__input::placeholder {
    color: rgba(255, 255, 255, 0.36);
  }

  .ms__caret {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    padding: 0;
    background: none;
    border: none;
    color: var(--c-white);
    cursor: pointer;
  }

  .ms__caret svg {
    transition: transform 0.15s ease;
  }

  .ms--open .ms__caret svg {
    transform: rotate(180deg);
  }

  .ms__list {
    position: absolute;
    z-index: 20;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    margin: 0;
    padding: 6px 0;
    list-style: none;
    max-height: 220px;
    overflow-y: auto;
    background: var(--c-black);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 8px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.45);
  }

  .ms__option {
    padding: 10px 14px;
    font: 400 15px / 1.3 var(--ff-r);
    color: var(--c-white);
    cursor: pointer;
  }

  .ms__option:hover,
  .ms__option--active {
    background: rgba(255, 255, 255, 0.08);
  }

  .ms__option--selected {
    color: rgba(255, 255, 255, 0.4);
  }

  .ms__empty {
    padding: 10px 14px;
    font: 400 14px / 1.3 var(--ff-r);
    color: rgba(255, 255, 255, 0.45);
  }
</style>

<script>
  function normalize(value) {
    return value.trim().toLowerCase();
  }

  function initMultiSelect(root) {
    if (root.dataset.msReady === 'true') return;
    root.dataset.msReady = 'true';

    const options = JSON.parse(root.dataset.options || '[]');
    const control = root.querySelector('[data-ms-control]');
    const tagsEl = root.querySelector('[data-ms-tags]');
    const input = root.querySelector('[data-ms-input]');
    const list = root.querySelector('[data-ms-list]');
    const caret = root.querySelector('[data-ms-caret]');
    const hidden = root.querySelector('[data-ms-value]');

    if (!control || !tagsEl || !input || !list || !caret || !hidden) return;

    const emptyPlaceholder = input.placeholder;
    let selected = [];
    let activeIndex = -1;
    let open = false;

    function syncHidden() {
      hidden.value = selected.join(', ');
    }

    function setOpen(next) {
      open = next;
      root.classList.toggle('ms--open', open);
      input.setAttribute('aria-expanded', String(open));
      list.hidden = !open;
      if (!open) activeIndex = -1;
    }

    function renderTags() {
      tagsEl.replaceChildren(
        ...selected.map((value) => {
          const tag = document.createElement('span');
          tag.className = 'ms__tag';
          tag.append(document.createTextNode(value));

          const remove = document.createElement('button');
          remove.type = 'button';
          remove.className = 'ms__tag-x';
          remove.setAttribute('aria-label', `Remove ${value}`);
          remove.innerHTML =
            '<svg width="8" height="8" viewBox="0 0 8 8" fill="none" aria-hidden="true"><path d="M1 1L7 7" stroke="currentColor" stroke-width=".6"/><path d="M7 1L1 7" stroke="currentColor" stroke-width=".6"/></svg>';
          remove.addEventListener('click', (e) => {
            e.stopPropagation();
            selected = selected.filter((item) => item !== value);
            syncHidden();
            renderTags();
            renderList();
            input.focus();
          });

          tag.append(remove);
          return tag;
        }),
      );
      input.placeholder = selected.length ? '' : emptyPlaceholder;
    }

    function filteredOptions() {
      const query = normalize(input.value);
      return options.filter((opt) => {
        if (selected.some((s) => normalize(s) === normalize(opt))) return false;
        if (!query) return true;
        return normalize(opt).includes(query);
      });
    }

    function renderList() {
      const items = filteredOptions();
      list.replaceChildren();

      if (!items.length) {
        const empty = document.createElement('li');
        empty.className = 'ms__empty';
        empty.textContent = input.value.trim()
          ? 'Press Enter to add custom value'
          : 'No options';
        list.append(empty);
        activeIndex = -1;
        return;
      }

      if (activeIndex >= items.length) activeIndex = items.length - 1;

      items.forEach((opt, index) => {
        const li = document.createElement('li');
        li.className = 'ms__option' + (index === activeIndex ? ' ms__option--active' : '');
        li.setAttribute('role', 'option');
        li.textContent = opt;
        li.addEventListener('mousedown', (e) => {
          e.preventDefault();
          addValue(opt);
        });
        list.append(li);
      });
    }

    function addValue(raw) {
      const value = raw.trim();
      if (!value) return;
      if (selected.some((s) => normalize(s) === normalize(value))) {
        input.value = '';
        setOpen(false);
        return;
      }
      const match = options.find((opt) => normalize(opt) === normalize(value));
      selected = [...selected, match || value];
      input.value = '';
      syncHidden();
      renderTags();
      setOpen(false);
      input.focus();
    }

    function openAndRender() {
      setOpen(true);
      renderList();
    }

    control.addEventListener('click', (e) => {
      if (e.target.closest('.ms__tag-x')) return;
      input.focus();
    });

    caret.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      if (open) {
        setOpen(false);
      } else {
        openAndRender();
        input.focus();
      }
    });

    input.addEventListener('input', () => {
      if (!input.value.trim()) {
        setOpen(false);
        return;
      }
      activeIndex = 0;
      openAndRender();
    });

    input.addEventListener('keydown', (e) => {
      const items = filteredOptions();

      if (e.key === 'ArrowDown') {
        if (!open) return;
        e.preventDefault();
        activeIndex = items.length ? (activeIndex + 1) % items.length : -1;
        renderList();
        return;
      }

      if (e.key === 'ArrowUp') {
        if (!open) return;
        e.preventDefault();
        activeIndex = items.length
          ? (activeIndex <= 0 ? items.length - 1 : activeIndex - 1)
          : -1;
        renderList();
        return;
      }

      if (e.key === 'Enter') {
        e.preventDefault();
        if (open && activeIndex >= 0 && items[activeIndex]) {
          addValue(items[activeIndex]);
        } else if (input.value.trim()) {
          addValue(input.value);
        }
        return;
      }

      if (e.key === 'Escape') {
        setOpen(false);
        return;
      }

      if (e.key === 'Backspace' && !input.value && selected.length) {
        selected = selected.slice(0, -1);
        syncHidden();
        renderTags();
        setOpen(false);
      }
    });

    document.addEventListener('click', (e) => {
      if (!root.contains(e.target)) setOpen(false);
    });

    renderTags();
    syncHidden();
  }

  function initAll() {
    document.querySelectorAll('[data-multi-select]').forEach(initMultiSelect);
  }

  initAll();
  document.addEventListener('astro:page-load', initAll);
</script>
